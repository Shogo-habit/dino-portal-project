---
import Layout from '../layouts/Layout.astro';
---

<Layout title="お問い合わせ | Dino-Portal" activeTab="contact" description="Dino-Portalへのお問い合わせフォームです。サイトのご感想、ご質問、データの不整合に関するフィードバックはこちらから送信してください。">
    <div class="contact-container" style="max-width: 800px; margin: 0 auto;">
        <!-- HEADER -->
        <section class="page-header" style="margin-bottom: 30px;">
            <h2 class="page-title">お問い合わせ</h2>
        </section>

        <!-- CONTENT PANEL -->
        <div class="hud-panel contact-panel" style="padding: 40px; background: rgba(1, 10, 18, 0.6); border-color: rgba(0, 242, 255, 0.15); position: relative;">
            <div class="hud-corner top-left"></div>
            <div class="hud-corner bottom-right"></div>

            <div class="contact-intro" style="margin-bottom: 30px; border-bottom: 1px dashed rgba(0, 242, 255, 0.15); padding-bottom: 20px;">
                <p style="font-size: 13.5px; line-height: 1.8; color: var(--text-dim); margin: 0;">
                  Dino-Portalのご利用ありがとうございます。当サイトに関するご質問、古生物データに関するフィードバック、またはお仕事のご依頼やアフィリエイト広告に関する提携のご相談がございましたら、以下のコンソール（入力フォーム）より必要事項をご入力の上、送信データを作成してください。
                </p>
            </div>

            <!-- Form -->
            <form id="contact-form" class="hud-form" style="display: flex; flex-direction: column; gap: 20px;">
                <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                    <label for="form-name" style="font-family: var(--font-mono); font-size: 11px; color: var(--primary-neon); letter-spacing: 1px;">
                      [ NAME ] お名前 <span style="color: var(--alert-neon);">*</span>
                    </label>
                    <input type="text" id="form-name" name="name" required placeholder="例: 恐竜 太郎" style="background: rgba(1, 10, 18, 0.8); border: 1px solid rgba(0, 242, 255, 0.2); padding: 12px; color: var(--text-main); font-family: inherit; font-size: 14px; border-radius: 4px; transition: all 0.3s;" />
                </div>

                <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                    <label for="form-email" style="font-family: var(--font-mono); font-size: 11px; color: var(--primary-neon); letter-spacing: 1px;">
                      [ EMAIL ] メールアドレス <span style="color: var(--alert-neon);">*</span>
                    </label>
                    <input type="email" id="form-email" name="email" required placeholder="例: dino-fan@example.com" style="background: rgba(1, 10, 18, 0.8); border: 1px solid rgba(0, 242, 255, 0.2); padding: 12px; color: var(--text-main); font-family: inherit; font-size: 14px; border-radius: 4px; transition: all 0.3s;" />
                </div>

                <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                    <label for="form-type" style="font-family: var(--font-mono); font-size: 11px; color: var(--primary-neon); letter-spacing: 1px;">
                      [ CATEGORY ] お問い合わせ種別 <span style="color: var(--alert-neon);">*</span>
                    </label>
                    <select id="form-type" name="type" required style="background: rgba(1, 10, 18, 0.8); border: 1px solid rgba(0, 242, 255, 0.2); padding: 12px; color: var(--text-main); font-family: inherit; font-size: 14px; border-radius: 4px; transition: all 0.3s;">
                        <option value="" disabled selected>選択してください</option>
                        <option value="data">古生物データへのご指摘・修正依頼</option>
                        <option value="ads">アフィリエイト広告・提携について</option>
                        <option value="feedback">サイトへのフィードバック</option>
                        <option value="other">その他のお問い合わせ</option>
                    </select>
                </div>

                <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                    <label for="form-subject" style="font-family: var(--font-mono); font-size: 11px; color: var(--primary-neon); letter-spacing: 1px;">
                      [ SUBJECT ] 件名
                    </label>
                    <input type="text" id="form-subject" name="subject" placeholder="例: ティラノサウルスの学説について" style="background: rgba(1, 10, 18, 0.8); border: 1px solid rgba(0, 242, 255, 0.2); padding: 12px; color: var(--text-main); font-family: inherit; font-size: 14px; border-radius: 4px; transition: all 0.3s;" />
                </div>

                <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                    <label for="form-message" style="font-family: var(--font-mono); font-size: 11px; color: var(--primary-neon); letter-spacing: 1px;">
                      [ MESSAGE ] お問い合わせ内容 <span style="color: var(--alert-neon);">*</span>
                    </label>
                    <textarea id="form-message" name="message" required rows="6" placeholder="お問い合わせ内容を詳しくご記入ください。" style="background: rgba(1, 10, 18, 0.8); border: 1px solid rgba(0, 242, 255, 0.2); padding: 12px; color: var(--text-main); font-family: inherit; font-size: 14px; border-radius: 4px; transition: all 0.3s; resize: vertical;"></textarea>
                </div>

                <div class="form-actions" style="margin-top: 10px;">
                    <button type="submit" id="submit-btn" style="background: rgba(0, 242, 255, 0.05); border: 1px solid var(--primary-neon); color: var(--primary-neon); padding: 14px 24px; font-family: var(--font-mono); font-weight: bold; font-size: 13px; letter-spacing: 1.5px; border-radius: 4px; cursor: pointer; transition: all 0.3s; width: 100%; text-transform: uppercase;">
                        [ TRANSMIT DATA ] 送信する
                    </button>
                </div>
            </form>

            <!-- Loading overlay -->
            <div id="loading-overlay" style="display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(1, 10, 18, 0.95); z-index: 10; flex-direction: column; align-items: center; justify-content: center; border-radius: 4px;">
                <div class="transmitting-text" style="font-family: var(--font-mono); color: var(--primary-neon); font-size: 16px; letter-spacing: 2px; margin-bottom: 10px; animation: blink 1s infinite;">
                  CONNECTING TO ARCHIVE SERVERS...
                </div>
                <div class="transmitting-sub" style="font-family: var(--font-mono); color: var(--text-dim); font-size: 11px;">
                  TRANSMITTING ENCRYPTED PACKETS [0%]
                </div>
            </div>

            <!-- Success message -->
            <div id="success-message" style="display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(1, 10, 18, 0.95); z-index: 20; flex-direction: column; align-items: center; justify-content: center; padding: 40px; text-align: center; border-radius: 4px;">
                <div class="success-icon" style="color: var(--secondary-neon); font-size: 40px; margin-bottom: 20px;">✓</div>
                <h3 style="color: var(--secondary-neon); font-family: var(--font-mono); font-size: 18px; letter-spacing: 1.5px; margin: 0 0 15px 0;">
                  TRANSMISSION COMPLETED
                </h3>
                <p style="font-size: 13.5px; line-height: 1.8; color: var(--text-dim); max-width: 500px; margin-bottom: 30px;">
                  お問い合わせデータの送信に成功しました。運営者の受信用コンソールにルーティングされました。<br>
                  通常、3営業日以内にご入力いただいたメールアドレス宛に折り返し返信パケットを送信いたします。
                </p>
                <button id="reset-btn" style="background: rgba(0, 255, 102, 0.05); border: 1px solid var(--secondary-neon); color: var(--secondary-neon); padding: 10px 20px; font-family: var(--font-mono); font-weight: bold; font-size: 11px; border-radius: 4px; cursor: pointer; transition: all 0.3s;">
                  [ RESET CONSOLE ] 送信フォームに戻る
                </button>
            </div>
        </div>

        <div style="margin-top: 35px; text-align: center;">
            <a href="/" class="nav-link" style="text-decoration: none;">[ ホームに戻る ]</a>
        </div>
    </div>
</Layout>

<style>
    input:focus, select:focus, textarea:focus {
        outline: none;
        border-color: var(--primary-neon) !important;
        box-shadow: 0 0 8px rgba(0, 242, 255, 0.15);
        background: rgba(1, 10, 18, 0.9) !important;
    }

    #submit-btn:hover {
        background: var(--primary-neon) !important;
        color: #000 !important;
        box-shadow: 0 0 15px var(--primary-neon);
    }
    
    #reset-btn:hover {
        background: var(--secondary-neon) !important;
        color: #000 !important;
        box-shadow: 0 0 15px var(--secondary-neon);
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }
</style>

<script>
    function initContactForm() {
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const submitBtn = document.getElementById('submit-btn');
        const loadingOverlay = document.getElementById('loading-overlay');
        const successMessage = document.getElementById('success-message');
        const resetBtn = document.getElementById('reset-btn');
        const transmittingSub = document.querySelector('.transmitting-sub');

        if (loadingOverlay) loadingOverlay.style.display = 'none';
        if (successMessage) successMessage.style.display = 'none';

        if (form && submitBtn && loadingOverlay && successMessage && resetBtn) {
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                
                loadingOverlay.style.display = 'flex';
                
                let progress = 0;
                const interval = setInterval(() => {
                    progress += 20;
                    if (transmittingSub) {
                        transmittingSub.textContent = `TRANSMITTING ENCRYPTED PACKETS [${progress}%]`;
                    }
                    if (progress >= 100) {
                        clearInterval(interval);
                        
                        loadingOverlay.style.display = 'none';
                        successMessage.style.display = 'flex';
                        
                        form.reset();
                    }
                }, 300);
            });

            resetBtn.addEventListener('click', () => {
                successMessage.style.display = 'none';
            });
        }
    }

    document.addEventListener('astro:page-load', initContactForm);
</script>
