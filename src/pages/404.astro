---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 SPECIMEN NOT FOUND | Dino-Portal" activeTab="">
    <div style="display: flex; justify-content: center; align-items: center; min-height: 60vh; padding: 20px;">
        <div class="hud-panel" style="max-width: 600px; width: 100%; padding: 40px; text-align: center; border-color: var(--alert-neon); box-shadow: 0 0 25px rgba(255, 0, 85, 0.15); position: relative;">
            <!-- 装飾コーナー -->
            <div class="hud-corner top-left" style="border-top-color: var(--alert-neon); border-left-color: var(--alert-neon);"></div>
            <div class="hud-corner bottom-right" style="border-bottom-color: var(--alert-neon); border-right-color: var(--alert-neon);"></div>

            <!-- 警告マーク -->
            <div style="font-size: 64px; color: var(--alert-neon); margin-bottom: 20px; animation: pulse 2s infinite;">⚠️</div>

            <h1 style="font-family: var(--font-mono); color: var(--alert-neon); font-size: 32px; margin-bottom: 10px; letter-spacing: 2px;">
                [ ERROR: 404 ]
            </h1>
            <h2 style="font-family: var(--font-sans); color: var(--text-main); font-size: 18px; margin-bottom: 30px; letter-spacing: 1px;">
                SPECIMEN NOT FOUND / 標本未検出
            </h2>

            <div style="border-top: 1px solid rgba(255, 0, 85, 0.2); border-bottom: 1px solid rgba(255, 0, 85, 0.2); padding: 20px 0; margin-bottom: 40px;">
                <p style="font-size: 14px; color: var(--text-dim); line-height: 1.8; margin: 0; text-align: left;">
                    システム警告: リクエストされた標本ID、遺伝子配列データ、または古生物アーカイブはメインサーバー上に存在しないか、インデックスから削除された可能性があります。
                </p>
            </div>

            <a href="/" style="display: inline-block; padding: 12px 30px; border: 1px solid var(--primary-neon); background: rgba(0, 242, 255, 0.05); color: var(--primary-neon); text-decoration: none; font-family: var(--font-mono); font-size: 14px; transition: all 0.3s ease; box-shadow: 0 0 10px rgba(0, 242, 255, 0.1);">
                > [ RETURN TO COMMAND CENTER ]
            </a>
        </div>
    </div>
</Layout>

<style>
    @keyframes pulse {
        0% { opacity: 0.6; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.05); }
        100% { opacity: 0.6; transform: scale(1); }
    }
</style>
