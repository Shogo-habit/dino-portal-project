---
import Layout from '../../layouts/Layout.astro';
import { DINOSAURS } from '../../data/dinosaurs';
import { QUIZ_SPECIMENS } from '../../data/quiz';
import { EXAM_QUESTIONS } from '../../data/exam';
---

<Layout title="恐竜クイズ | Dino-Portal" activeTab="quiz" description="メジャー恐竜のシルエット・近接拡大・生態データから種を当てる、恐竜クイズコーナー。">
    <!-- Data bridge to client script -->
    <div id="quiz-data-bridge" 
         data-dinosaurs={JSON.stringify(DINOSAURS)} 
         data-quiz-specimens={JSON.stringify(QUIZ_SPECIMENS)} 
         data-exam-questions={JSON.stringify(EXAM_QUESTIONS)} 
         style="display: none;">
    </div>

    <div class="quiz-container">
        <!-- HEADER -->
        <section class="page-header" style="margin-bottom: 20px;">
            <h2 class="page-title">恐竜クイズ</h2>
            <p class="page-subtitle">DINO QUIZ CHALLENGE</p>
        </section>

        <!-- START PANEL -->
        <div id="quiz-start-panel" class="hud-panel start-panel">
            <div class="hud-corner top-left"></div>
            <div class="hud-corner bottom-right"></div>
            
            <div class="panel-icon">☵</div>
            <h3>恐竜クイズ ＆ 検定模擬試験</h3>
            
            <!-- モード選択タブ -->
            <div class="mode-selector" style="display: flex; justify-content: center; gap: 15px; margin-bottom: 25px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 15px;">
                <button class="mode-tab active" data-mode="aptitude" style="flex: 1; max-width: 250px; background: rgba(0, 242, 255, 0.03); border: 1px solid rgba(0, 242, 255, 0.2); padding: 12px; border-radius: 4px; color: var(--text-dim); cursor: pointer; transition: all 0.3s ease;">
                    <div style="font-size: 14px; font-weight: bold; color: var(--primary-neon); transition: color 0.3s ease;">適性解析クイズ</div>
                    <div style="font-size: 9px; font-family: var(--font-mono); text-transform: uppercase; margin-top: 3px; letter-spacing: 1px;">Aptitude Quiz (5 Qs)</div>
                </button>
                <button class="mode-tab" data-mode="exam" style="flex: 1; max-width: 250px; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--panel-border); padding: 12px; border-radius: 4px; color: var(--text-dim); cursor: pointer; transition: all 0.3s ease;">
                    <div style="font-size: 14px; font-weight: bold; color: var(--text-main); transition: color 0.3s ease;">恐竜学検定 模擬試験</div>
                    <div style="font-size: 9px; font-family: var(--font-mono); text-transform: uppercase; margin-top: 3px; letter-spacing: 1px;">Mock Exam (10 Qs)</div>
                </button>
            </div>

            <p id="mode-description-text" style="line-height: 1.8; color: var(--text-dim); font-size: 14px; max-width: 600px; margin: 0 auto 25px auto;">
                恐竜のシルエット、クローズアップ、または生態データから名前を当てるクイズです。<br>
                全5問に回答し、あなたの正解率（同期率）を測定します。
            </p>

            <!-- 難易度セレクター -->
            <div class="difficulty-section" style="margin-bottom: 30px;">
                <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 2px;">
                    // 難易度を選択 (SELECT DIFFICULTY)
                </div>
                <div class="difficulty-buttons" style="display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;">
                    <button class="diff-btn active" data-difficulty="beginner" style="min-width: 120px;">
                        初級<span style="display:block; font-size: 9px; font-family: var(--font-mono); color: var(--secondary-neon); margin-top: 2px;">BEGINNER</span>
                    </button>
                    <button class="diff-btn" data-difficulty="intermediate" style="min-width: 120px;">
                        中級<span style="display:block; font-size: 9px; font-family: var(--font-mono); color: var(--secondary-neon); margin-top: 2px;">INTERMEDIATE</span>
                    </button>
                    <button class="diff-btn" data-difficulty="advanced" style="min-width: 120px;">
                        上級<span style="display:block; font-size: 9px; font-family: var(--font-mono); color: var(--secondary-neon); margin-top: 2px;">ADVANCED</span>
                    </button>
                    <button class="diff-btn locked" data-difficulty="master" disabled style="min-width: 120px;">
                        恐竜博士<span style="display:block; font-size: 9px; font-family: var(--font-mono); color: var(--text-dim); margin-top: 2px;">LOCKED</span>
                    </button>
                </div>
            </div>

            <div class="start-meta" style="font-family: var(--font-mono); font-size: 12px; color: var(--secondary-neon); margin-bottom: 25px;">
                [ <span id="difficulty-label-display">初級</span>ハイスコア: <span id="start-high-score">0%</span> ]
            </div>

            <button id="start-test-btn" class="action-btn">
                クイズスタート
            </button>
        </div>

        <!-- MAIN QUIZ PANEL (Hidden Initially) -->
        <div id="quiz-main-panel" class="hud-panel quiz-panel" style="display: none;">
            <div class="hud-corner bottom-right"></div>

            <!-- Quiz Header Info -->
            <div class="quiz-progress-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--panel-border); padding-bottom: 12px; margin-bottom: 20px; font-family: var(--font-mono); font-size: 12px;">
                <span class="quiz-step-indicator" style="color: var(--primary-neon);">[ QUESTION: 01 / 05 ]</span>
                <span class="quiz-score-indicator" style="color: var(--secondary-neon);">正解数: 0</span>
            </div>

            <div class="quiz-content-layout" style="display: flex; gap: 30px; flex-wrap: wrap;">
                <!-- Visual/Question Left Area -->
                <div class="quiz-question-visual-area" style="flex: 1.2; min-width: 300px;">
                    <!-- Exam Metadata Header (Visible only in Exam Mode) -->
                    <div id="exam-metadata-header" style="display: none; font-family: var(--font-mono); font-size: 11px; color: var(--secondary-neon); margin-bottom: 12px; border-bottom: 1px dashed rgba(0, 242, 255, 0.2); padding-bottom: 8px;">
                    </div>

                    <!-- Question Prompt Title -->
                    <div class="question-prompt" id="question-prompt-text" style="font-family: var(--font-mono); font-size: 14px; color: var(--text-main); margin-bottom: 15px; border-left: 3px solid var(--primary-neon); padding-left: 15px;">
                        クイズをロード中...
                    </div>

                    <!-- Visual Frame Container -->
                    <div class="quiz-visual-frame" style="width: 100%; aspect-ratio: 16 / 9; background: #000; border: 1px solid var(--panel-border); border-radius: 4px; overflow: hidden; position: relative; display: flex; align-items: center; justify-content: center;">
                        <!-- Silhouette Mode Graphic -->
                        <div id="visual-silhouette-container" style="display: none; width: 100%; height: 100%; align-items: center; justify-content: center;">
                            <img id="silhouette-image" src="" alt="Silhouette Specimen" style="height: 85%; width: auto; object-fit: contain; filter: drop-shadow(0 0 12px var(--primary-neon));">
                        </div>

                        <!-- Close-Up Mode Graphic -->
                        <div id="visual-closeup-container" style="display: none; width: 100%; height: 100%; overflow: hidden; position: relative;">
                            <img id="closeup-image" src="" alt="Close-Up Specimen" style="width: 100%; height: 100%; object-fit: contain;">
                        </div>

                        <!-- Telemetry (Text) Mode Graphic -->
                        <div id="visual-text-container" style="display: none; width: 100%; height: 100%; padding: 25px; display: flex; flex-direction: column; justify-content: center; font-family: var(--font-mono);">
                            <div class="telemetry-log" style="font-size: 12px; line-height: 1.8; color: var(--secondary-neon); height: 100%; overflow-y: auto;">
                                <div style="border-bottom: 1px dashed rgba(0, 242, 255, 0.2); padding-bottom: 5px; margin-bottom: 8px;">[ 恐竜データ解析情報 ]</div>
                                <div id="telemetry-detail-text"></div>
                            </div>
                        </div>

                        <!-- Scanning overlay line -->
                        <div class="quiz-scan-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; background: linear-gradient(180deg, rgba(0, 242, 255, 0) 0%, rgba(0, 242, 255, 0.03) 40%, rgba(0, 242, 255, 0.08) 50%, rgba(0, 242, 255, 0.03) 60%, rgba(0, 242, 255, 0) 100%); animation: quiz-beam 6s linear infinite;"></div>
                    </div>
                </div>

                <!-- Control/Answer Choices Right Area -->
                <div class="quiz-answers-area" style="flex: 1; min-width: 280px; display: flex; flex-direction: column; justify-content: center;">
                    <div class="answer-label" style="font-family: var(--font-mono); font-size: 13px; color: var(--text-dim); margin-bottom: 10px;">選択肢</div>
                    
                    <div class="choices-container" id="quiz-choices-box" style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px;">
                        <!-- Choice Buttons will be injected here -->
                    </div>

                    <!-- Answer Explaining Panel (Initially Hidden) -->
                    <div id="answer-explanation-panel" style="display: none; animation: scan-info-fade 0.4s ease forwards;">
                        <div class="explanation-box" style="border: 1px solid var(--panel-border); background: rgba(0, 242, 255, 0.01); padding: 15px; border-radius: 4px; position: relative;">
                            <!-- Correctness Indicator Tag -->
                            <div id="correctness-indicator" style="font-family: var(--font-mono); font-weight: bold; font-size: 16px; margin-bottom: 8px; letter-spacing: 2px;"></div>
                            
                            <!-- Detailed analysis text -->
                            <p id="explanation-detail-text" style="font-size: 13px; line-height: 1.6; color: var(--text-dim); margin: 0 0 15px 0;"></p>
                            
                            <!-- Next button -->
                            <button id="next-question-btn" class="action-btn" style="width: 100%; padding: 10px; font-size: 13px;">
                                次の問題へ >
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SCANNING LOADING PANEL (Hidden Initially) -->
        <div id="quiz-scan-loading" class="hud-panel loading-panel" style="display: none; padding: 60px 20px; text-align: center;">
            <div class="scan-radar-icon" style="color: var(--primary-neon); margin-bottom: 15px; animation: compass-spin 2s linear infinite;">☲</div>
            <h3 style="color: var(--primary-neon); font-family: var(--font-mono); letter-spacing: 3px; font-size: 18px; margin-bottom: 5px;">LOADING QUESTION...</h3>
            <p style="font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); margin-bottom: 15px;">次のクイズを生成中</p>
            <div style="width: 100%; height: 6px; background: rgba(0, 242, 255, 0.05); border: 1px solid var(--panel-border); overflow: hidden; width: 220px; margin: 0 auto;">
                <div id="scan-progress-fill" style="width: 0%; height: 100%; background: var(--primary-neon); box-shadow: 0 0 10px var(--primary-neon);"></div>
            </div>
        </div>

        <!-- RESULT PANEL (Hidden Initially) -->
        <div id="quiz-result-panel" class="hud-panel result-panel" style="display: none;">
            <div class="hud-corner top-left"></div>
            <div class="hud-corner bottom-right"></div>
            
            <div id="high-score-announcement" style="display: none; border: 1px solid var(--alert-neon); background: rgba(255, 0, 90, 0.05); border-left-width: 5px; color: var(--alert-neon); font-family: var(--font-mono); font-size: 12px; padding: 12px 20px; margin-bottom: 25px; letter-spacing: 1px; border-radius: 0 4px 4px 0; animation: glitch 0.5s ease-in-out;">
                ▲ NEW HIGH SCORE: 自己記録を更新しました！
            </div>

            <div style="text-align: center; margin-bottom: 40px;">
                <div class="result-title" style="font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); letter-spacing: 2px;">// FINISHED //</div>
                <h3 style="font-size: 24px; margin: 10px 0 25px 0;">クイズ結果レポート</h3>

                <!-- Synchronization Score Circle Meter -->
                <div class="sync-meter-container" style="position: relative; width: 160px; height: 160px; margin: 0 auto 20px auto; display: flex; align-items: center; justify-content: center;">
                    <svg style="width: 100%; height: 100%; transform: rotate(-90deg);">
                        <circle cx="80" cy="80" r="70" fill="transparent" stroke="rgba(0, 242, 255, 0.06)" stroke-width="8"></circle>
                        <circle id="sync-meter-circle" cx="80" cy="80" r="70" fill="transparent" stroke="var(--primary-neon)" stroke-width="8" stroke-dasharray="440" stroke-dashoffset="440" style="transition: stroke-dashoffset 1.5s cubic-bezier(0.1, 0.8, 0.1, 1); filter: drop-shadow(0 0 8px var(--primary-neon));"></circle>
                    </svg>
                    <div class="sync-score-text-box" style="position: absolute; text-align: center; font-family: var(--font-mono);">
                        <div id="result-score-percent" style="font-size: 32px; font-weight: bold; color: var(--text-main); line-height: 1;">0%</div>
                        <div style="font-size: 9px; color: var(--primary-neon); margin-top: 4px; letter-spacing: 1.5px;">正解率</div>
                    </div>
                </div>

                <div id="result-rank-badge" style="font-family: var(--font-mono); font-size: 16px; font-weight: bold; color: var(--secondary-neon); letter-spacing: 2px;"></div>
                <p id="result-rank-desc" style="font-size: 13px; color: var(--text-dim); max-width: 500px; margin: 10px auto 0 auto; line-height: 1.6;"></p>
            </div>

            <!-- Review Items -->
            <div class="review-section" style="margin-top: 40px; border-top: 1px solid var(--panel-border); padding-top: 30px;">
                <h4 style="font-family: var(--font-mono); color: var(--primary-neon); margin-bottom: 20px; font-size: 13px;">// クイズで出題された恐竜の復習 (図鑑へリンク)</h4>
                
                <div class="review-grid" id="result-review-box" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 15px; margin-bottom: 30px;">
                    <!-- Review cards dynamically injected here -->
                </div>
            </div>

            <!-- Result Actions -->
            <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
                <button id="retry-test-btn" class="action-btn" style="border-color: var(--secondary-neon); color: var(--secondary-neon); box-shadow: 0 0 10px rgba(0, 255, 102, 0.1);">
                    もう一度挑戦する
                </button>
                <a href="/dictionary" class="nav-link" style="display: flex; align-items: center; justify-content: center; border: 1px solid var(--panel-border); background: var(--panel-bg); text-decoration: none; padding: 12px 30px; font-size: 14px; font-family: var(--font-mono); text-transform: uppercase; font-weight: 700; border-radius: 4px; transition: all 0.3s ease;">
                    [ 図鑑アーカイブへ ]
                </a>
            </div>
        </div>
    </div>

    <!-- Client-side Interactive Logic -->
    <script>
        const HIGH_SCORE_BASE_KEY = 'dino_portal_quiz_highscore';
        
        let quizState = {
            dinosaurs: [],
            quizSpecimens: [],
            examQuestions: [],
            questions: [], // Array of generated questions
            currentStep: 0,
            score: 0,
            answersRecorded: [], // Aptitude: { dino, correct }, Exam: { questionObj, correct, chosenIndex, correctIndex }
            selectedDifficulty: 'beginner', // デフォルト
            selectedMode: 'aptitude' // 'aptitude' | 'exam'
        };

        function getHighScoreKey(difficulty: string, mode: string) {
            if (mode === 'exam') {
                return `dino_portal_exam_highscore_${difficulty}`;
            }
            return `${HIGH_SCORE_BASE_KEY}_${difficulty}`;
        }

        function initQuizProgram() {
            const bridge = document.getElementById('quiz-data-bridge');
            if (!bridge) return;

            // Load data
            quizState.dinosaurs = JSON.parse(bridge.getAttribute('data-dinosaurs') || '[]');
            quizState.quizSpecimens = JSON.parse(bridge.getAttribute('data-quiz-specimens') || '[]');
            quizState.examQuestions = JSON.parse(bridge.getAttribute('data-exam-questions') || '[]');

            // Bind start button
            const startPanel = document.getElementById('quiz-start-panel');
            const mainPanel = document.getElementById('quiz-main-panel');
            const resultPanel = document.getElementById('quiz-result-panel');
            const startBtn = document.getElementById('start-test-btn');
            const retryBtn = document.getElementById('retry-test-btn');
            
            if (startBtn) {
                startBtn.addEventListener('click', startTest);
            }
            if (retryBtn) {
                retryBtn.addEventListener('click', startTest);
            }

            // Bind mode selector tabs
            const modeTabs = document.querySelectorAll('.mode-tab');
            const modeDesc = document.getElementById('mode-description-text');
            const diffButtons = document.querySelectorAll('.diff-btn');
            
            modeTabs.forEach(tab => {
                tab.addEventListener('click', (e) => {
                    const target = e.currentTarget as HTMLButtonElement;
                    modeTabs.forEach(t => {
                        t.classList.remove('active');
                        const titleEl = t.querySelector('div');
                        if (titleEl) titleEl.style.color = 'var(--text-main)';
                    });
                    
                    target.classList.add('active');
                    const activeTitle = target.querySelector('div');
                    if (activeTitle) activeTitle.style.color = 'var(--primary-neon)';
                    
                    const mode = target.getAttribute('data-mode') || 'aptitude';
                    quizState.selectedMode = mode;
                    
                    // Update mode description and difficulty buttons availability
                    if (mode === 'exam') {
                        modeDesc.innerHTML = `
                            恐竜学検定の公式シミュレーターです。分類・生態・歴史・地質の4分野から出題されます。<br>
                            <strong>全10問の4択テスト</strong>を行い、<strong>正解率70%以上（7問以上正解）で合格</strong>となります。
                        `;
                        
                        // Disable advanced & master
                        diffButtons.forEach(btn => {
                            const diff = btn.getAttribute('data-difficulty');
                            if (diff === 'advanced' || diff === 'master') {
                                btn.classList.add('locked');
                                (btn as HTMLButtonElement).disabled = true;
                                const subText = btn.querySelector('span');
                                if (subText) subText.innerText = 'LOCKED';
                            }
                        });
                        
                        // If selected difficulty is advanced/master, fallback to intermediate
                        if (quizState.selectedDifficulty === 'advanced' || quizState.selectedDifficulty === 'master') {
                            quizState.selectedDifficulty = 'intermediate';
                            diffButtons.forEach(btn => {
                                const diff = btn.getAttribute('data-difficulty');
                                if (diff === 'intermediate') {
                                    btn.classList.add('active');
                                } else {
                                    btn.classList.remove('active');
                                }
                            });
                            const diffLabel = document.getElementById('difficulty-label-display');
                            if (diffLabel) diffLabel.innerText = '中級';
                        }
                    } else {
                        modeDesc.innerHTML = `
                            恐竜のシルエット、クローズアップ、または生態データから名前を当てるクイズです。<br>
                            全5問に回答し、あなたの正解率（同期率）を測定します。
                        `;
                        
                        // Enable advanced (master remains locked)
                        diffButtons.forEach(btn => {
                            const diff = btn.getAttribute('data-difficulty');
                            if (diff === 'advanced') {
                                btn.classList.remove('locked');
                                (btn as HTMLButtonElement).disabled = false;
                                const subText = btn.querySelector('span');
                                if (subText) subText.innerText = 'ADVANCED';
                            }
                        });
                    }
                    
                    displayHighScore();
                });
            });

            // Bind difficulty selector buttons
            diffButtons.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const target = e.currentTarget as HTMLButtonElement;
                    if (target.classList.contains('locked')) return;
                    
                    diffButtons.forEach(b => b.classList.remove('active'));
                    target.classList.add('active');
                    
                    quizState.selectedDifficulty = target.getAttribute('data-difficulty') || 'beginner';
                    
                    // Update labels
                    const diffLabel = document.getElementById('difficulty-label-display');
                    if (diffLabel) {
                        diffLabel.innerText = target.firstChild ? target.firstChild.textContent!.trim() : '初級';
                    }
                    
                    displayHighScore();
                });
            });

            // Display highscore on start panel
            displayHighScore();
        }

        function displayHighScore() {
            const hsSpan = document.getElementById('start-high-score');
            if (hsSpan) {
                const key = getHighScoreKey(quizState.selectedDifficulty, quizState.selectedMode);
                const hs = localStorage.getItem(key) || '0';
                hsSpan.innerText = `${hs}%`;
            }
        }

        // Generate random test of 5 or 10 questions
        function startTest() {
            document.getElementById('quiz-start-panel')!.style.display = 'none';
            document.getElementById('quiz-result-panel')!.style.display = 'none';
            
            if (quizState.selectedMode === 'exam') {
                // Exam Mode: 10 random questions of chosen difficulty
                const filteredQuestions = quizState.examQuestions.filter(
                    (q: any) => q.level === quizState.selectedDifficulty
                );
                
                const questionsToUse = filteredQuestions.length > 0 ? filteredQuestions : quizState.examQuestions;
                const shuffled = [...questionsToUse].sort(() => 0.5 - Math.random());
                const selected = shuffled.slice(0, 10);
                
                quizState.questions = selected.map((q: any) => {
                    return {
                        questionObj: q,
                        mode: 'exam',
                        choices: q.choices,
                        correctIndex: q.correctIndex
                    };
                });
            } else {
                // Aptitude Mode: 5 random specimens of chosen difficulty
                // Filter specimens by selected difficulty
                const filteredSpecimens = quizState.quizSpecimens.filter(
                    (specimen: any) => specimen.difficulty === quizState.selectedDifficulty
                );

                // Fallback to all if empty
                const specimensToUse = filteredSpecimens.length > 0 ? filteredSpecimens : quizState.quizSpecimens;

                // Randomly select 5 specimens
                const shuffledSpecimens = [...specimensToUse].sort(() => 0.5 - Math.random());
                const selectedSpecimens = shuffledSpecimens.slice(0, 5);

                // Modes: 0 = Silhouette, 1 = Close-Up, 2 = Telemetry (Text)
                quizState.questions = selectedSpecimens.map((specimen: any) => {
                    const d = quizState.dinosaurs.find((item: any) => item.id === specimen.id);
                    const mode = Math.floor(Math.random() * 3); // 0, 1, 2
                    
                    // Generate 4 unique choices from specimens of the SAME difficulty
                    const incorrects = quizState.dinosaurs
                        .filter((item: any) => item.id !== d.id && specimensToUse.some((qs: any) => qs.id === item.id))
                        .sort(() => 0.5 - Math.random())
                        .slice(0, 3);
                    
                    const choices = [d, ...incorrects].sort(() => 0.5 - Math.random());

                    return {
                        specimen: specimen,
                        dino: d,
                        mode: mode,
                        choices: choices
                    };
                });
            }

            quizState.currentStep = 0;
            quizState.score = 0;
            quizState.answersRecorded = [];

            // Load first question
            loadQuestion();
        }

        function loadQuestion() {
            const currentQ = quizState.questions[quizState.currentStep];
            const maxSteps = quizState.selectedMode === 'exam' ? 10 : 5;
            
            // Update UI indices
            const stepIndicator = document.querySelector('.quiz-step-indicator');
            const scoreIndicator = document.querySelector('.quiz-score-indicator');
            
            if (stepIndicator) {
                const stepNum = quizState.currentStep + 1;
                const formattedStep = stepNum < 10 ? `0${stepNum}` : `${stepNum}`;
                const formattedMax = maxSteps < 10 ? `0${maxSteps}` : `${maxSteps}`;
                stepIndicator.innerText = `[ QUESTION: ${formattedStep} / ${formattedMax} ]`;
            }
            if (scoreIndicator) {
                scoreIndicator.innerText = `正解数: ${quizState.score}`;
            }

            // Setup prompt and visual mode
            const promptText = document.getElementById('question-prompt-text');
            const silContainer = document.getElementById('visual-silhouette-container');
            const closeContainer = document.getElementById('visual-closeup-container');
            const textContainer = document.getElementById('visual-text-container');
            
            silContainer!.style.display = 'none';
            closeContainer!.style.display = 'none';
            textContainer!.style.display = 'none';
            
            // Hide explanation
            document.getElementById('answer-explanation-panel')!.style.display = 'none';

            // Enable choices interaction
            const choicesBox = document.getElementById('quiz-choices-box');
            choicesBox!.innerHTML = '';

            const visualFrame = document.querySelector('.quiz-visual-frame') as HTMLElement;
            const leftArea = document.querySelector('.quiz-question-visual-area') as HTMLElement;
            const rightArea = document.querySelector('.quiz-answers-area') as HTMLElement;
            const contentLayout = document.querySelector('.quiz-content-layout') as HTMLElement;
            const examMetaHeader = document.getElementById('exam-metadata-header');

            if (quizState.selectedMode === 'exam') {
                const q = currentQ.questionObj;
                promptText!.innerText = q.question;
                
                // 1カラム表示に切り替え、ボックスを非表示
                visualFrame.style.display = 'none';
                leftArea.style.flex = 'none';
                leftArea.style.width = '100%';
                rightArea.style.flex = 'none';
                rightArea.style.width = '100%';
                rightArea.style.marginTop = '20px';
                contentLayout.style.flexDirection = 'column';

                // メタデータヘッダー表示
                examMetaHeader!.style.display = 'block';
                examMetaHeader!.innerHTML = `
                    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                        <span>[ SYSTEM: EXAM_ACTIVE ]</span>
                        <span>[ FIELD: ${q.category} ]</span>
                        <span>[ TARGET: ${q.level === 'beginner' ? '初級' : '中級'} ]</span>
                    </div>
                `;

                // Populate choices
                currentQ.choices.forEach((choiceText: string, index: number) => {
                    const btn = document.createElement('button');
                    btn.className = 'nav-link';
                    btn.style.width = '100%';
                    btn.style.textAlign = 'left';
                    btn.style.padding = '12px 20px';
                    btn.style.fontSize = '14px';
                    btn.style.background = 'var(--panel-bg)';
                    btn.style.border = '1px solid var(--panel-border)';
                    btn.style.display = 'flex';
                    btn.style.justifyContent = 'space-between';
                    btn.style.alignItems = 'center';
                    btn.style.cursor = 'pointer';
                    
                    btn.innerHTML = `
                        <span style="font-family: sans-serif;">[ 0${index + 1} ] &nbsp; ${choiceText}</span>
                        <span class="choice-indicator" style="font-family: var(--font-mono); color: var(--primary-neon);"></span>
                    `;
                    
                    btn.addEventListener('click', () => submitAnswer(index, btn));
                    choicesBox!.appendChild(btn);
                });

            } else {
                // Aptitude Mode
                // 従来の左右2カラム表示に戻す
                visualFrame.style.display = 'flex';
                leftArea.style.flex = '1.2';
                leftArea.style.width = '';
                rightArea.style.flex = '1';
                rightArea.style.width = '';
                rightArea.style.marginTop = '0';
                contentLayout.style.flexDirection = 'row';

                examMetaHeader!.style.display = 'none';

                if (currentQ.mode === 0) {
                    // Silhouette Mode
                    promptText!.innerText = `この影絵が示す恐竜の名前を選択してください。`;
                    silContainer!.style.display = 'flex';
                    
                    const silImg = document.getElementById('silhouette-image') as HTMLImageElement;
                    silImg.src = `/images/silhouette/${currentQ.dino.id}.webp`;
                } else if (currentQ.mode === 1) {
                    // Close-Up Mode
                    promptText!.innerText = `拡大表示された特徴（${currentQ.specimen.featureName}）から名前を当ててください。`;
                    closeContainer!.style.display = 'block';
                    
                    const closeImg = document.getElementById('closeup-image') as HTMLImageElement;
                    closeImg.src = `/${currentQ.dino.image}`;
                    
                    // Apply transform styling dynamically
                    closeImg.style.transform = `scale(${currentQ.specimen.zoom})`;
                    closeImg.style.transformOrigin = `${currentQ.specimen.originX} ${currentQ.specimen.originY}`;
                } else {
                    // Telemetry (Text) Mode
                    promptText!.innerText = `一部が伏せられた以下の解析ログから恐竜を特定してください。`;
                    textContainer!.style.display = 'flex';
                    
                    const telemetryText = document.getElementById('telemetry-detail-text');
                    
                    // Hide species name and scientific name with placeholder
                    let rawDesc = currentQ.dino.description;
                    const regexName = new RegExp(currentQ.dino.name, 'g');
                    const maskedDesc = rawDesc.replace(regexName, ' ［ ？？？ ］ ');
                    
                    let traitsHtml = currentQ.dino.bioTraits.map((t: any) => {
                        return `<br>&bull; 特性: ${t.trait} -> [${t.value}] - ${t.detail}`;
                    }).join('');

                    telemetryText!.innerHTML = `
                        <strong>&bull; 出現地域:</strong> ${currentQ.dino.region}<br>
                        <strong>&bull; 生息年代:</strong> ${currentQ.dino.era}<br>
                        <strong>&bull; 全長/推定体重:</strong> ${currentQ.dino.length} / ${currentQ.dino.weight}<br>
                        <strong>&bull; 分類系統:</strong> ${currentQ.dino.group || '未分類'}<br>
                        <strong>&bull; 説明文:</strong><br>
                        <p style="padding-left: 10px; margin-top: 5px; color: var(--text-dim);">${maskedDesc}</p>
                        <strong>&bull; パラメータ特性:</strong> ${traitsHtml}
                    `;
                }

                // Populate choices (Dinosaur objects)
                currentQ.choices.forEach((choice: any, index: number) => {
                    const btn = document.createElement('button');
                    btn.className = 'nav-link';
                    btn.style.width = '100%';
                    btn.style.textAlign = 'left';
                    btn.style.padding = '12px 20px';
                    btn.style.fontSize = '14px';
                    btn.style.background = 'var(--panel-bg)';
                    btn.style.border = '1px solid var(--panel-border)';
                    btn.style.display = 'flex';
                    btn.style.justifyContent = 'space-between';
                    btn.style.alignItems = 'center';
                    btn.style.cursor = 'pointer';
                    
                    btn.innerHTML = `
                        <span>[ 0${index + 1} ] &nbsp; ${choice.name}</span>
                        <span class="choice-indicator" style="font-family: var(--font-mono); color: var(--primary-neon);"></span>
                    `;
                    
                    btn.addEventListener('click', () => submitAnswer(choice, btn));
                    choicesBox!.appendChild(btn);
                });
            }

            // Display main panel
            document.getElementById('quiz-main-panel')!.style.display = 'block';
        }

        function submitAnswer(chosenVal: any, clickedBtn: HTMLElement) {
            const currentQ = quizState.questions[quizState.currentStep];
            let isCorrect = false;

            if (quizState.selectedMode === 'exam') {
                const chosenIndex = chosenVal as number;
                const correctIndex = currentQ.correctIndex;
                isCorrect = chosenIndex === correctIndex;

                // Record answer
                quizState.answersRecorded.push({
                    questionObj: currentQ.questionObj,
                    correct: isCorrect,
                    chosenIndex: chosenIndex,
                    correctIndex: correctIndex
                });
            } else {
                const chosenDino = chosenVal;
                const correctDino = currentQ.dino;
                isCorrect = chosenDino.id === correctDino.id;

                // Record answer
                quizState.answersRecorded.push({
                    dino: correctDino,
                    correct: isCorrect
                });
            }

            if (isCorrect) {
                quizState.score++;
            }

            // Disable all choice buttons and colorize
            const choicesBox = document.getElementById('quiz-choices-box');
            const buttons = Array.from(choicesBox!.getElementsByTagName('button'));
            
            buttons.forEach((btn: any, index: number) => {
                btn.disabled = true;
                
                if (quizState.selectedMode === 'exam') {
                    const correctIndex = currentQ.correctIndex;
                    if (index === correctIndex) {
                        btn.style.borderColor = 'var(--secondary-neon)'; // Green
                        btn.style.background = 'rgba(0, 255, 102, 0.05)';
                        btn.querySelector('.choice-indicator').innerText = '正解 (CORRECT)';
                        btn.querySelector('.choice-indicator').style.color = 'var(--secondary-neon)';
                    } else if (index === chosenVal && !isCorrect) {
                        btn.style.borderColor = 'var(--alert-neon)'; // Red/Pink
                        btn.style.background = 'rgba(255, 0, 90, 0.05)';
                        btn.querySelector('.choice-indicator').innerText = '不正解 (WRONG)';
                        btn.querySelector('.choice-indicator').style.color = 'var(--alert-neon)';
                    } else {
                        btn.style.opacity = '0.5';
                        btn.querySelector('.choice-indicator').innerText = '----';
                        btn.querySelector('.choice-indicator').style.color = 'var(--text-dim)';
                    }
                } else {
                    const correctDino = currentQ.dino;
                    const text = btn.innerText;
                    const btnDino = currentQ.choices.find((c: any) => text.includes(c.name));
                    
                    if (btnDino.id === correctDino.id) {
                        btn.style.borderColor = 'var(--secondary-neon)'; // Green
                        btn.style.background = 'rgba(0, 255, 102, 0.05)';
                        btn.querySelector('.choice-indicator').innerText = '正解 (CORRECT)';
                        btn.querySelector('.choice-indicator').style.color = 'var(--secondary-neon)';
                    } else if (btnDino.id === chosenVal.id && !isCorrect) {
                        btn.style.borderColor = 'var(--alert-neon)'; // Red/Pink
                        btn.style.background = 'rgba(255, 0, 90, 0.05)';
                        btn.querySelector('.choice-indicator').innerText = '不正解 (WRONG)';
                        btn.querySelector('.choice-indicator').style.color = 'var(--alert-neon)';
                    } else {
                        btn.style.opacity = '0.5';
                        btn.querySelector('.choice-indicator').innerText = '----';
                        btn.querySelector('.choice-indicator').style.color = 'var(--text-dim)';
                    }
                }
            });

            // Show explanation
            const expPanel = document.getElementById('answer-explanation-panel');
            const correctnessInd = document.getElementById('correctness-indicator');
            const expDetail = document.getElementById('explanation-detail-text');
            const nextBtn = document.getElementById('next-question-btn');
            
            if (isCorrect) {
                correctnessInd!.innerText = "▲ 正解 (CORRECT)";
                correctnessInd!.style.color = "var(--secondary-neon)";
            } else {
                correctnessInd!.innerText = "▼ 不正解 (WRONG)";
                correctnessInd!.style.color = "var(--alert-neon)";
            }

            if (quizState.selectedMode === 'exam') {
                const q = currentQ.questionObj;
                expDetail!.innerHTML = `
                    <strong>正解: [0${q.correctIndex + 1}] ${q.choices[q.correctIndex]}</strong><br>
                    <p style="margin-top: 8px; color: var(--text-main); font-size: 13px; font-family: sans-serif;">
                        ${q.explanation}
                    </p>
                `;
            } else {
                const correctDino = currentQ.dino;
                expDetail!.innerHTML = `
                    <strong>正解: ${correctDino.name}</strong> (${correctDino.scientificName})<br>
                    ${correctDino.description}<br>
                    <span style="color: var(--secondary-neon); font-size: 11px; font-family: var(--font-mono); display: block; margin-top: 5px;">
                        [解説]: ${currentQ.specimen.featureName}
                    </span>
                `;
            }

            const maxSteps = quizState.selectedMode === 'exam' ? 10 : 5;
            if (quizState.currentStep < maxSteps - 1) {
                nextBtn!.innerText = "次の問題へ >";
            } else {
                nextBtn!.innerText = "テスト結果へ >";
            }

            // Bind next question action
            const newNextBtn = nextBtn!.cloneNode(true) as HTMLButtonElement;
            nextBtn!.parentNode!.replaceChild(newNextBtn, nextBtn!);
            
            newNextBtn.addEventListener('click', proceedToNext);

            expPanel!.style.display = 'block';
        }

        function proceedToNext() {
            quizState.currentStep++;
            const maxSteps = quizState.selectedMode === 'exam' ? 10 : 5;
            
            if (quizState.currentStep < maxSteps) {
                showScanningScreen(() => {
                    loadQuestion();
                });
            } else {
                showScanningScreen(() => {
                    showResults();
                });
            }
        }

        function showScanningScreen(callback: () => void) {
            document.getElementById('quiz-main-panel')!.style.display = 'none';
            
            const loadingPanel = document.getElementById('quiz-scan-loading');
            const progressBar = document.getElementById('scan-progress-fill');
            
            loadingPanel!.style.display = 'block';
            progressBar!.style.width = '0%';
            
            let val = 0;
            const interval = setInterval(() => {
                val += 15;
                if (progressBar) progressBar.style.width = `${Math.min(100, val)}%`;
                
                if (val >= 100) {
                    clearInterval(interval);
                    setTimeout(() => {
                        loadingPanel!.style.display = 'none';
                        callback();
                    }, 200);
                }
            }, 80);
        }

        function showResults() {
            const maxSteps = quizState.selectedMode === 'exam' ? 10 : 5;
            const finalScorePercent = Math.round((quizState.score / maxSteps) * 100);
            
            // Record High Score in localStorage per difficulty
            const hsKey = getHighScoreKey(quizState.selectedDifficulty, quizState.selectedMode);
            const previousHighScore = parseInt(localStorage.getItem(hsKey) || '0');
            let isNewHighScore = false;
            
            if (finalScorePercent > previousHighScore) {
                localStorage.setItem(hsKey, finalScorePercent.toString());
                isNewHighScore = true;
                displayHighScore();
            }

            // Render Circle SVG score animation
            const meterCircle = document.getElementById('sync-meter-circle');
            const scoreText = document.getElementById('result-score-percent');
            
            if (meterCircle) {
                const circumference = 440;
                const offset = circumference - (circumference * finalScorePercent) / 100;
                meterCircle.style.strokeDashoffset = offset.toString();
            }
            if (scoreText) {
                scoreText.innerText = `${finalScorePercent}%`;
            }

            // High score alert display
            const hsAlert = document.getElementById('high-score-announcement');
            hsAlert!.style.display = (isNewHighScore && finalScorePercent > 0) ? 'block' : 'none';

            // Score details and Rank badge
            const rankBadge = document.getElementById('result-rank-badge');
            const rankDesc = document.getElementById('result-rank-desc');

            const isExam = quizState.selectedMode === 'exam';
            const isPass = finalScorePercent >= 70;

            if (isExam) {
                const resultTitle = document.querySelector('.result-title');
                if (resultTitle) {
                    resultTitle.innerHTML = isPass 
                        ? `<span style="color: var(--secondary-neon); font-weight: bold; border: 1px solid var(--secondary-neon); padding: 2px 8px; border-radius: 3px;">★ PASS (合格) ★</span>`
                        : `<span style="color: var(--alert-neon); font-weight: bold; border: 1px solid var(--alert-neon); padding: 2px 8px; border-radius: 3px;">▲ FAIL (不合格) ▲</span>`;
                }

                if (isPass) {
                    rankBadge!.innerText = `【合格】恐竜学検定 ${quizState.selectedDifficulty === 'beginner' ? '初級' : '中級'} 模擬試験`;
                    rankBadge!.style.color = "var(--secondary-neon)";
                    rankDesc!.innerHTML = `
                        <div class="hud-panel certificate-box" style="border: 2px solid var(--secondary-neon); background: rgba(0, 255, 102, 0.03); padding: 20px; margin-top: 15px; border-radius: 4px; text-align: center; position: relative; animation: glitch 0.5s ease-in-out;">
                            <div style="font-family: var(--font-mono); font-size: 10px; color: var(--secondary-neon); margin-bottom: 10px; text-transform: uppercase;">// CERTIFICATE OF EXAM PASSAGE //</div>
                            <h4 style="font-size: 20px; color: #fff; margin-bottom: 12px; font-family: sans-serif; letter-spacing: 2px;">合格証</h4>
                            <p style="font-size: 13px; color: var(--text-main); margin-bottom: 15px;">
                                あなたは恐竜学検定（模擬試験）において、基準（70%以上）を超える優秀な成績を収め、見事合格したことをここに証します。
                            </p>
                            <div style="font-family: var(--font-mono); font-size: 11px; color: var(--secondary-neon);">
                                正解率: ${finalScorePercent}% (10問中 ${quizState.score}問正解)<br>
                                認定レベル: ${quizState.selectedDifficulty === 'beginner' ? '初級' : '中級'}
                            </div>
                        </div>
                    `;
                } else {
                    rankBadge!.innerText = `【不合格】恐竜学検定 ${quizState.selectedDifficulty === 'beginner' ? '初級' : '中級'} 模擬試験`;
                    rankBadge!.style.color = "var(--alert-neon)";
                    rankDesc!.innerHTML = `
                        <div class="hud-panel fail-box" style="border: 1px dashed var(--alert-neon); background: rgba(255, 0, 90, 0.02); padding: 20px; margin-top: 15px; border-radius: 4px; text-align: center;">
                            <div style="font-family: var(--font-mono); font-size: 10px; color: var(--alert-neon); margin-bottom: 10px; text-transform: uppercase;">// EXAM RESULT: FAILED //</div>
                            <h4 style="font-size: 18px; color: #fff; margin-bottom: 12px; font-family: sans-serif;">不合格 (得点不足)</h4>
                            <p style="font-size: 13px; color: var(--text-dim); margin-bottom: 15px;">
                                合格ラインである正解率70%（10問中7問正解）に届きませんでした。復習レビューを確認し、再受験してリベンジしましょう。
                            </p>
                            <div style="font-family: var(--font-mono); font-size: 11px; color: var(--alert-neon);">
                                正解率: ${finalScorePercent}% (10問中 ${quizState.score}問正解)<br>
                                目標: 70%以上
                            </div>
                        </div>
                    `;
                }
            } else {
                const resultTitle = document.querySelector('.result-title');
                if (resultTitle) resultTitle.innerHTML = '// FINISHED //';

                if (finalScorePercent === 100) {
                    rankBadge!.innerText = "Sランク: 恐竜マスター (全問正解！)";
                    rankBadge!.style.color = "var(--secondary-neon)";
                    rankDesc!.innerText = "素晴らしい知識量です！全問正解おめでとうございます。これであなたも立派な恐竜マスターです。";
                } 
                else if (finalScorePercent === 80) {
                    rankBadge!.innerText = "Aランク: 恐竜博士級 (優秀！)";
                    rankBadge!.style.color = "var(--primary-neon)";
                    rankDesc!.innerText = "非常に優秀な成績です！あと一歩で満点でした。図鑑やトピックスを読み直して完璧を目指しましょう。";
                }
                else if (finalScorePercent === 60) {
                    rankBadge!.innerText = "Bランク: 恐竜ファン級 (普通)";
                    rankBadge!.style.color = "var(--text-main)";
                    rankDesc!.innerText = "恐竜の知識をしっかり持っていますね。さらにスキャンや図鑑を学習すれば、さらに高得点が狙えます！";
                }
                else {
                    rankBadge!.innerText = "Cランク: 恐竜初心者級 (もっと学ぼう)";
                    rankBadge!.style.color = "var(--alert-neon)";
                    rankDesc!.innerText = "少し難しかったかもしれません。図鑑アーカイブの恐竜 dataや、サイズ比較などを確認して再学習してみましょう！";
                }
            }

            // Render review grid/list
            const reviewBox = document.getElementById('result-review-box');
            reviewBox!.innerHTML = '';

            const reviewSectionTitle = document.querySelector('.review-section h4');

            if (isExam) {
                if (reviewSectionTitle) reviewSectionTitle.innerHTML = '// 試験の復習と解説レポート (DETAILS & EXPLANATION)';
                
                reviewBox!.style.display = 'flex';
                reviewBox!.style.flexDirection = 'column';
                reviewBox!.style.gap = '15px';

                quizState.answersRecorded.forEach((record: any, index: number) => {
                    const q = record.questionObj;
                    const item = document.createElement('div');
                    item.className = 'hud-panel';
                    item.style.padding = '20px';
                    
                    const borderColor = record.correct ? 'var(--secondary-neon)' : 'var(--alert-neon)';
                    const badgeText = record.correct ? '正解 (CORRECT)' : '不正解 (WRONG)';
                    const badgeColor = record.correct ? 'var(--secondary-neon)' : 'var(--alert-neon)';
                    
                    item.style.borderColor = borderColor;

                    const userValText = q.choices[record.chosenIndex];
                    const correctValText = q.choices[record.correctIndex];

                    item.innerHTML = `
                        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed rgba(255,255,255,0.1); padding-bottom: 8px; margin-bottom: 12px; font-family: var(--font-mono); font-size: 11px;">
                            <span>QUESTION 0${index + 1} [分野: ${q.category}]</span>
                            <span style="color: ${badgeColor}; font-weight: bold; border: 1px solid ${badgeColor}; padding: 1px 6px; border-radius: 2px;">${badgeText}</span>
                        </div>
                        <h5 style="font-size: 14px; color: var(--text-main); margin-bottom: 12px; font-family: sans-serif;">${q.question}</h5>
                        <div style="font-size: 12px; color: var(--text-dim); margin-bottom: 10px;">
                            <strong>あなたの回答:</strong> <span style="color: ${record.correct ? 'var(--secondary-neon)' : 'var(--alert-neon)'};">${userValText}</span><br>
                            ${!record.correct ? `<strong>正解の回答:</strong> <span style="color: var(--secondary-neon);">${correctValText}</span><br>` : ''}
                        </div>
                        <div style="background: rgba(255,255,255,0.01); border: 1px solid rgba(255,255,255,0.05); padding: 12px; border-radius: 4px; font-size: 12px; line-height: 1.6; color: var(--text-dim); font-family: sans-serif;">
                            <strong style="color: var(--primary-neon); display: block; margin-bottom: 4px; font-family: var(--font-mono);">[解説 / ANALYSIS]:</strong>
                            ${q.explanation}
                        </div>
                    `;
                    
                    reviewBox!.appendChild(item);
                });
            } else {
                if (reviewSectionTitle) reviewSectionTitle.innerHTML = '// クイズで出題された恐竜の復習 (図鑑へリンク)';
                
                reviewBox!.style.display = 'grid';
                reviewBox!.style.gridTemplateColumns = 'repeat(auto-fill, minmax(130px, 1fr))';
                reviewBox!.style.gap = '15px';

                quizState.answersRecorded.forEach(record => {
                    const card = document.createElement('a');
                    card.href = `/dictionary/${record.dino.id}`;
                    card.style.textDecoration = 'none';
                    card.style.color = 'inherit';
                    
                    const borderColor = record.correct ? 'var(--secondary-neon)' : 'var(--alert-neon)';
                    const badgeText = record.correct ? '正解' : '不正解';
                    const badgeColor = record.correct ? 'var(--secondary-neon)' : 'var(--alert-neon)';

                    card.innerHTML = `
                        <div class="related-card hud-panel" style="cursor: pointer; height: 100%; border-color: ${borderColor};">
                            <div class="related-img-wrap" style="width: 100%; height: auto; aspect-ratio: 16 / 9; overflow: hidden; position: relative;">
                                <img src="/${record.dino.image}" alt="${record.dino.name}" loading="lazy" decoding="async" style="width: 100%; height: 100%; object-fit: cover;">
                                <span style="position: absolute; top: 5px; right: 5px; font-family: var(--font-mono); font-size: 8px; background: rgba(0,0,0,0.8); color: ${badgeColor}; border: 1px solid ${badgeColor}; padding: 1px 4px; border-radius: 2px;">
                                    ${badgeText}
                                </span>
                            </div>
                            <h4 class="related-name" style="font-size: 12px; margin: 8px 0 4px 0; color: var(--text-main);">${record.dino.name}</h4>
                            <div class="related-meta" style="font-size: 9px; color: var(--text-dim);">${record.dino.era}</div>
                        </div>
                    `;
                    
                    reviewBox!.appendChild(card);
                });
            }

            // Show result panel
            document.getElementById('quiz-result-panel')!.style.display = 'block';
        }

        // Initialize quiz on page load/transition
        document.addEventListener('astro:page-load', initQuizProgram);
    </script>
</Layout>

<style>
    .quiz-container {
        max-width: 900px;
        margin: 0 auto;
    }
    .start-panel {
        text-align: center;
        padding: 60px 40px;
        border-color: var(--panel-border);
    }
    .panel-icon {
        font-size: 48px;
