---
import Layout from '../../layouts/Layout.astro';
import { TOPICS } from '../../data/topics';
---

<Layout title="恐竜トピックス | Dino-Portal" activeTab="topics" description="恐竜の生態推測や歴史的変化など、古生物学における詳細なトピック記事一覧。">
    <section class="page-header">
        <h2 class="page-title">恐竜トピックス</h2>
    </section>
    
    <div class="topic-list">
        {TOPICS.map(topic => (
            <a href={`/topics/${topic.id}`} style="text-decoration: none; color: inherit; display: block; margin-bottom: 20px;">
                <div class="topic-card hud-panel" style="cursor: pointer; display: flex; gap: 20px; flex-wrap: wrap;">
                    <img src={`/${topic.image}`} class="topic-thumb" alt={topic.title} loading="lazy" decoding="async">
                    <div class="topic-summary" style="flex: 1; min-width: 250px;">
                        <div class="topic-meta" style="font-size: 11px; color: var(--primary-neon); margin-bottom: 5px; font-family: var(--font-mono);">
                            {topic.date}
                        </div>
                        <h3 class="topic-title" style="margin: 0 0 10px 0; font-size: 20px; color: var(--text-main);">{topic.title}</h3>
                        <p class="topic-desc" style="font-size: 13px; color: var(--text-dim); line-height: 1.6; margin: 0;">{topic.summary}</p>
                    </div>
                </div>
            </a>
        ))}
    </div>
</Layout>
