---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const topics = await getCollection('topics');
const sortedTopics = topics
  .map(entry => entry.data)
  .sort((a, b) => b.date.localeCompare(a.date));

// Extract unique categories from topic entries dynamically for ultimate extensibility
const uniqueCategories = [...new Set(topics.map(entry => entry.data.category))].filter(Boolean);

// Prescribed order for categories, user-specified
const categoryOrder = ["basics", "introduction", "theory", "museum_goods", "ranking"];

// Sort dynamically discovered categories based on the prescribed order
const sortedCategories = uniqueCategories.sort((a, b) => {
  let indexA = categoryOrder.indexOf(a);
  let indexB = categoryOrder.indexOf(b);
  
  if (indexA === -1) indexA = 999;
  if (indexB === -1) indexB = 999;
  
  if (indexA !== indexB) {
    return indexA - indexB;
  }
  return a.localeCompare(b);
});

// Category Japanese/English labels mapping table
const categoryLabels: Record<string, { ja: string; en: string }> = {
  introduction: { ja: "恐竜紹介", en: "INTRODUCTION" },
  basics: { ja: "基礎知識", en: "BASICS" },
  theory: { ja: "学説・研究", en: "THEORIES" },
  ranking: { ja: "ランキング", en: "RANKINGS" },
  museum_goods: { ja: "グッズ・博物館", en: "SPOTS & GOODS" },
};

// Generate labels dynamically for all found categories (fallbacks included)
const categoriesWithLabels = sortedCategories.map(cat => {
  const label = categoryLabels[cat] || {
    ja: cat.charAt(0).toUpperCase() + cat.slice(1),
    en: cat.toUpperCase()
  };
  return { id: cat, ...label };
});
---

<Layout title="恐竜トピックス | Dino-Portal" activeTab="topics" description="恐竜の生態推測や歴史的変化など、古生物学における詳細なトピック記事一覧。">
    <section class="page-header">
        <h2 class="page-title">恐竜トピックス</h2>
    </section>

    <!-- Cyber-styled HUD Control Panel -->
    <div class="topics-control-panel hud-panel">
        <div class="filter-group">
            <button class="filter-btn active" data-filter="all">
                <span class="btn-bracket">[</span> ALL <span class="btn-bracket">]</span>
            </button>
            {categoriesWithLabels.map(cat => (
                <button class="filter-btn" data-filter={cat.id}>
                    <span class="btn-bracket">[</span> {cat.ja} <span class="btn-bracket">]</span>
                </button>
            ))}
        </div>
        <div class="sort-group">
            <label for="sort-select" class="sort-label">SORT ORDER // </label>
            <div class="select-wrapper">
                <select id="sort-select" class="sort-select">
                    <option value="newest">NEWEST FIRST [ 新着順 ]</option>
                    <option value="oldest">OLDEST FIRST [ 古い順 ]</option>
                </select>
            </div>
        </div>
    </div>
    
    <div class="no-results hud-panel">
        <div style="color: var(--alert-neon); margin-bottom: 10px; font-weight: bold; font-family: var(--font-mono);">WARNING // NO DATA ACQUIRED</div>
        <div>指定されたカテゴリに該当するトピックスは見つかりませんでした。</div>
    </div>

    <div class="topic-list">
        {sortedTopics.map(topic => (
            <a href={`/topics/${topic.id}/`} class="topic-item" data-category={topic.category} data-date={topic.date} style="text-decoration: none; color: inherit; display: block; margin-bottom: 20px;">
                <div class="topic-card hud-panel" style="cursor: pointer; display: flex; gap: 20px; flex-wrap: wrap;">
                    <img src={`/${topic.image}`} class="topic-thumb" alt={topic.title} loading="lazy" decoding="async">
                    <div class="topic-summary" style="flex: 1; min-width: 250px;">
                        <div class="topic-meta-wrapper" style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px;">
                            <div class="topic-meta" style="font-size: 11px; color: var(--primary-neon); font-family: var(--font-mono);">
                                {topic.date}
                            </div>
                            <span class="topic-badge">
                                {categoryLabels[topic.category]?.en || topic.category.toUpperCase()}
                            </span>
                        </div>
                        <h3 class="topic-title" style="margin: 0 0 10px 0; font-size: 20px; color: var(--text-main);">{topic.title}</h3>
                        <p class="topic-desc" style="font-size: 13px; color: var(--text-dim); line-height: 1.6; margin: 0;">{topic.summary}</p>
                    </div>
                </div>
            </a>
        ))}
    </div>
</Layout>

<style>
    /* HUD Control Panel Style */
    .topics-control-panel {
        margin-bottom: 30px;
        padding: 20px;
        background: rgba(0, 242, 255, 0.02);
        border: 1px solid var(--panel-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .filter-group {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .filter-btn {
        background: transparent;
        border: 1px solid transparent;
        color: var(--text-dim);
        font-family: var(--font-mono);
        font-size: 11px;
        padding: 8px 14px;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .btn-bracket {
        color: transparent;
        transition: color 0.25s ease;
    }

    .filter-btn:hover {
        color: var(--primary-neon);
    }

    .filter-btn:hover .btn-bracket {
        color: rgba(0, 242, 255, 0.5);
    }

    .filter-btn.active {
        color: #fff;
        text-shadow: 0 0 8px var(--primary-neon);
        border: 1px solid var(--panel-border);
        background: rgba(0, 242, 255, 0.1);
        box-shadow: 0 0 12px rgba(0, 242, 255, 0.15);
    }

    .filter-btn.active .btn-bracket {
        color: var(--primary-neon);
    }

    /* Sort Control Style */
    .sort-group {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .sort-label {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-dim);
        letter-spacing: 1.5px;
    }

    .select-wrapper {
        position: relative;
    }

    .sort-select {
        background: var(--bg-color);
        border: 1px solid var(--panel-border);
        color: var(--text-main);
        font-family: var(--font-mono);
        font-size: 11px;
        padding: 8px 12px;
        cursor: pointer;
        outline: none;
        transition: all 0.25s ease;
        appearance: none;
        -webkit-appearance: none;
        padding-right: 30px;
    }

    .select-wrapper::after {
        content: "▼";
        font-size: 8px;
        color: var(--primary-neon);
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
    }

    .sort-select:hover, .sort-select:focus {
        border-color: var(--primary-neon);
        box-shadow: 0 0 8px rgba(0, 242, 255, 0.2);
    }

    /* Topic Badge */
    .topic-badge {
        font-family: var(--font-mono);
        font-size: 9px;
        color: var(--secondary-neon);
        border: 1px solid rgba(0, 255, 102, 0.3);
        background: rgba(0, 255, 102, 0.05);
        padding: 2px 8px;
        border-radius: 2px;
        letter-spacing: 0.5px;
        text-shadow: 0 0 4px rgba(0, 255, 102, 0.3);
    }

    /* Topic List & Item Transitions */
    .topic-list {
        position: relative;
        min-height: 200px;
        transition: height 0.3s ease;
    }

    .topic-item {
        transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1), transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), margin-bottom 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        max-height: 500px;
        opacity: 1;
        transform: scale(1);
        overflow: hidden;
    }

    .topic-item.filtered-out {
        opacity: 0;
        transform: scale(0.95) translateY(-10px);
        max-height: 0;
        margin-bottom: 0 !important;
        pointer-events: none;
    }

    .topic-card {
        border-color: var(--panel-border);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .topic-card:hover {
        border-color: var(--primary-neon);
        box-shadow: 0 0 15px rgba(0, 242, 255, 0.15);
        background: rgba(0, 242, 255, 0.06);
    }

    /* No Results panel */
    .no-results {
        display: none;
        padding: 40px;
        text-align: center;
        background: rgba(255, 0, 85, 0.02);
        border: 1px dashed rgba(255, 0, 85, 0.3);
        margin-bottom: 30px;
        font-size: 14px;
        color: var(--text-dim);
    }
</style>

<script>
    function initFilters() {
        const filterButtons = document.querySelectorAll('.filter-btn');
        const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
        const topicList = document.querySelector('.topic-list');
        const topicItems = Array.from(document.querySelectorAll('.topic-item')) as HTMLElement[];
        const noResults = document.querySelector('.no-results') as HTMLElement;

        if (!topicList || topicItems.length === 0) return;

        let currentFilter = 'all';
        let currentSort = 'newest';

        function updateList() {
            let visibleCount = 0;

            // 1. Filtering
            topicItems.forEach(item => {
                const category = item.getAttribute('data-category');
                if (currentFilter === 'all' || category === currentFilter) {
                    item.classList.remove('filtered-out');
                    visibleCount++;
                } else {
                    item.classList.add('filtered-out');
                }
            });

            // Handle Empty State
            if (visibleCount === 0) {
                noResults.style.display = 'block';
            } else {
                noResults.style.display = 'none';
            }

            // 2. Sorting
            const sortedItems = [...topicItems].sort((a, b) => {
                const dateA = a.getAttribute('data-date') || '';
                const dateB = b.getAttribute('data-date') || '';
                
                if (currentSort === 'newest') {
                    return dateB.localeCompare(dateA);
                } else {
                    return dateA.localeCompare(dateB);
                }
            });

            // Re-append to DOM: active items first, then filtered-out items at the very end.
            // This prevents hidden items from dynamically triggering flash heights/margins
            // and causing weird white spaces between visible items when sorted.
            const visibleItems = sortedItems.filter(item => !item.classList.contains('filtered-out'));
            const hiddenItems = sortedItems.filter(item => item.classList.contains('filtered-out'));

            visibleItems.forEach(item => {
                topicList.appendChild(item);
            });
            hiddenItems.forEach(item => {
                topicList.appendChild(item);
            });
        }

        // Event listeners for Filters
        filterButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                filterButtons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentFilter = btn.getAttribute('data-filter') || 'all';
                updateList();
            });
        });

        // Event listener for Sort
        if (sortSelect) {
            sortSelect.addEventListener('change', (e) => {
                const target = e.target as HTMLSelectElement;
                currentSort = target.value;
                updateList();
            });
        }
    }

    // Run on initial load
    initFilters();

    // Run on view transition navigation (if Astro View Transitions is active in the project)
    document.addEventListener('astro:after-swap', initFilters);
</script>
