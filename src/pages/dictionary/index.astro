---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const dinosaurEntries = await getCollection('dinosaurs');
const DINOSAURS = dinosaurEntries.map(entry => entry.data);

const ERAS = [
    { id: '古生代', label: '古生代', period: '5億4100万 - 2億5100万年前' },
    { id: '三畳紀', label: '三畳紀', period: '2億5100万 - 2億0100万年前' },
    { id: 'ジュラ紀', label: 'ジュラ紀', period: '2億0100万 - 1億4500万年前' },
    { id: '白亜紀', label: '白亜紀', period: '1億4500万 - 6600万年前' }
];

const REGIONS = [
    { id: '北アメリカ', label: '北アメリカ' },
    { id: '南アメリカ', label: '南アメリカ' },
    { id: 'アジア', label: 'アジア' },
    { id: 'ロシア', label: 'ロシア' },
    { id: 'アフリカ', label: 'アフリカ' },
    { id: 'ヨーロッパ', label: 'ヨーロッパ' },
    { id: '日本', label: '日本' },
    { id: '海洋', label: '海洋' },
    { id: 'オセアニア', label: 'オセアニア' }
];

const GROUPS = [
    { id: '獣脚類', label: '獣脚類' },
    { id: '竜脚類', label: '竜脚類' },
    { id: '鳥脚類', label: '鳥脚類' },
    { id: '剣竜類', label: '剣竜類' },
    { id: '堅頭竜類', label: '堅頭竜類' },
    { id: 'よろい竜類', label: 'よろい竜類' },
    { id: '角竜類', label: '角竜類' },
    { id: '翼竜', label: '翼竜' },
    { id: '首長竜', label: '首長竜' },
    { id: '魚竜', label: '魚竜' },
    { id: 'その他', label: 'その他' }
];
---

<Layout title="恐竜図鑑 | Dino-Portal" activeTab="dictionary" description="150種以上の恐竜データを網羅したデジタル・アーカイブ。">
    <div class="archive-sticky-header">
        <section class="page-header" style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 20px; margin-bottom: 20px;">
        <div>
            <h2 class="page-title" style="margin-bottom: 5px;">恐竜図鑑</h2>
            <p class="page-subtitle">標本リスト : 総数 {DINOSAURS.length}　※恐竜以外の古生物も含みます</p>
        </div>
        <div class="search-header-wrap" style="display: flex; gap: 10px; align-items: center; flex-shrink: 0;">
            <select id="sort-order" class="search-input" style="width: auto; margin-bottom: 0; padding: 10px 15px; font-size: 14px; border-color: var(--primary-neon); background: rgba(0, 242, 255, 0.05); height: 43px;" aria-label="リストの並び替え">
                <option value="kana">並び順: かな順</option>
                <option value="size">並び順: サイズ順</option>
            </select>
            <input type="text" id="dino-search" class="search-input" placeholder="アーカイブ内を検索..." 
                   style="width: 300px; margin-bottom: 0; padding: 12px 15px; font-size: 14px; border-color: var(--primary-neon); background: rgba(0, 242, 255, 0.05); height: 43px;"
                   aria-label="恐竜の名前で検索">
        </div>
    </section>

    <!-- Filter Toggle & Active Chips -->
    <div class="filter-controls-header hud-panel" style="margin-bottom: 20px; padding: 10px 20px; display: flex; align-items: center; gap: 20px; justify-content: space-between; cursor: pointer;" id="filter-accordion-toggle">
        <div style="display: flex; align-items: center; gap: 15px; overflow-x: auto; scrollbar-width: none;" id="active-filter-chips">
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--primary-neon); white-space: nowrap;">フィルタ設定:</span>
            <div class="filter-chips-container" style="display: flex; gap: 8px;">
                <span style="font-size: 11px; color: var(--text-dim);">未設定</span>
            </div>
        </div>
        <div style="display: flex; align-items: center; gap: 15px; flex-shrink: 0;">
            <button id="filter-reset-btn" class="scan-tag-btn" style="padding: 4px 10px; font-size: 11px; display: none; margin: 0; cursor: pointer; height: auto; background: rgba(255, 0, 85, 0.05); border-color: rgba(255, 0, 85, 0.4); color: #ff0055; font-family: var(--font-mono); transition: all 0.3s ease;">
                [ リセット ]
            </button>
            <div style="display: flex; align-items: center; gap: 10px; color: var(--primary-neon); font-family: var(--font-mono); font-size: 12px; white-space: nowrap;">
                <span id="accordion-label">フィルタを展開</span>
                <span id="accordion-icon" style="transition: transform 0.3s ease;">[ + ]</span>
            </div>
        </div>
    </div>

    <!-- Collapsible Filter Content -->
    <div id="filter-accordion-content" style="display: none; margin-bottom: 30px;">
        <div class="hud-panel" style="padding: 10px 0; border-top: none;">
            <!-- Temporal Navigation -->
            <div class="timeline-wrapper" style="margin-bottom: 10px;">
                <div class="timeline-container">
                    <div class="timeline-label-fixed" style="padding: 0 30px; font-family: var(--font-mono); font-size: 12px; color: var(--primary-neon); border-right: 1px solid var(--panel-border); height: 100%; display: flex; align-items: center; white-space: nowrap; background: rgba(0, 242, 255, 0.05);">
                        年代フィルタ
                    </div>
                    <div class="timeline-track">
                        <div class="timeline-era active" data-era="">
                            <div class="era-marker"></div>
                            <span class="era-label">すべて</span>
                            <span class="era-period">ALL ERAS</span>
                        </div>
                        {ERAS.map((e, index) => (
                            <div class={`timeline-era ${index < ERAS.length - 1 ? 'has-arrow' : ''}`} data-era={e.id}>
                                <div class="era-marker"></div>
                                <span class="era-label">{e.label}</span>
                                <span class="era-period">{e.period}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Spatial Navigation -->
            <div class="timeline-wrapper" style="margin-bottom: 10px;">
                <div class="timeline-container region-timeline">
                    <div class="timeline-label-fixed" style="padding: 0 30px; font-family: var(--font-mono); font-size: 12px; color: var(--primary-neon); border-right: 1px solid var(--panel-border); height: 100%; display: flex; align-items: center; white-space: nowrap; background: rgba(0, 242, 255, 0.05);">
                        地域フィルタ
                    </div>
                    <div class="timeline-track">
                        <div class="timeline-region active" data-region="">
                            <div class="era-marker"></div>
                            <span class="era-label">すべて</span>
                        </div>
                        {REGIONS.map(r => (
                            <div class="timeline-region" data-region={r.id}>
                                <div class="era-marker"></div>
                                <span class="era-label">{r.label}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Taxonomic Navigation -->
            <div class="timeline-wrapper">
                <div class="timeline-container group-timeline">
                    <div class="timeline-label-fixed" style="padding: 0 30px; font-family: var(--font-mono); font-size: 12px; color: var(--primary-neon); border-right: 1px solid var(--panel-border); height: 100%; display: flex; align-items: center; white-space: nowrap; background: rgba(0, 242, 255, 0.05);">
                        系統フィルタ
                    </div>
                    <div class="timeline-track">
                        <div class="timeline-group active" data-group="">
                            <div class="era-marker"></div>
                            <span class="era-label">すべて</span>
                        </div>
                        {GROUPS.map(g => (
                            <div class="timeline-group" data-group={g.id}>
                                <div class="era-marker"></div>
                                <span class="era-label">{g.label}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>

    <!-- Hidden state stores -->
    <input type="hidden" id="filter-era" value="">
    <input type="hidden" id="filter-region" value="">
    <input type="hidden" id="filter-group" value="">

    <div class="dino-grid" id="dino-grid-content">
        {DINOSAURS.map(d => (
            <div class="dino-card hud-panel" data-id={d.id} data-name={d.name} data-kana={d.kana} data-scientific={d.scientificName} data-group={d.group || '未分類'} data-era={d.era} data-region={d.region} data-length={d.length} data-diet={d.diet}>
                <a href={`/dictionary/${d.id}/`} style="text-decoration: none; color: inherit; display: block; height: 100%;">
                    <div class="card-img-wrap">
                        <img src={`/${d.image}`} alt={d.name} loading="lazy" decoding="async" width="400" height="225">
                        <div class="collected-badge" style="display: none;">OBSERVED</div>
                    </div>
                    <div class="card-info">
                        <h3 class="card-title">{d.name}</h3>
                        <div class="card-tags" style="display: flex; gap: 5px; flex-wrap: wrap;">
                            <span class="card-tag group-tag">{d.group || '未分類'}</span>
                            <span class="card-tag">{d.era}</span>
                            <span class="card-tag">{d.diet}</span>
                        </div>
                    </div>
                </a>
            </div>
        ))}
    </div>

    <!-- Client-side filter and state scripts -->
    <script>
        const COLLECTION_KEY = 'dino_portal_saved_observations';
        const DICT_FILTERS_KEY = 'dino_portal_dict_filters';

        function initDictionary() {
            const search = document.getElementById('dino-search') as HTMLInputElement;
            const era = document.getElementById('filter-era') as HTMLInputElement;
            const region = document.getElementById('filter-region') as HTMLInputElement;
            const group = document.getElementById('filter-group') as HTMLInputElement;
            const sort = document.getElementById('sort-order') as HTMLSelectElement;
            const cardGrid = document.getElementById('dino-grid-content');
            if (!search || !era || !region || !group || !sort || !cardGrid) return;

            const cards = Array.from(cardGrid.getElementsByClassName('dino-card')) as HTMLElement[];

            // Hilper utils
            const hiraToKata = (str: string) => str.replace(/[\u3041-\u3096]/g, m => String.fromCharCode(m.charCodeAt(0) + 0x60));
            const kataToHira = (str: string) => str.replace(/[\u30a1-\u30f6]/g, m => String.fromCharCode(m.charCodeAt(0) - 0x60));
            const extractNumber = (str: string) => {
                if (!str) return 0;
                const match = str.match(/[0-9.]+/);
                return match ? parseFloat(match[0]) : 0;
            };

            // Read observed list
            const savedStr = localStorage.getItem(COLLECTION_KEY);
            const observedIds = savedStr ? JSON.parse(savedStr) : [];
            cards.forEach(card => {
                const id = card.getAttribute('data-id');
                const badge = card.querySelector('.collected-badge') as HTMLElement;
                if (id && observedIds.includes(id)) {
                    card.classList.add('is-collected');
                    if (badge) badge.style.display = 'block';
                } else {
                    card.classList.remove('is-collected');
                    if (badge) badge.style.display = 'none';
                }
            });

            // Set state
            const saveFiltersState = () => {
                const state = {
                    search: search.value,
                    era: era.value,
                    region: region.value,
                    group: group.value,
                    sort: sort.value
                };
                localStorage.setItem(DICT_FILTERS_KEY, JSON.stringify(state));
            };

            const loadFiltersState = () => {
                // 1. URL parameters check
                const params = new URLSearchParams(window.location.search);
                const pEra = params.get('era');
                const pRegion = params.get('region');
                const pGroup = params.get('group');
                const pSearch = params.get('search');
                
                if (pEra || pRegion || pGroup || pSearch) {
                    search.value = pSearch || '';
                    era.value = pEra || '';
                    region.value = pRegion || '';
                    group.value = pGroup || '';
                    sort.value = 'kana';
                    saveFiltersState();
                    return;
                }

                // 2. localStorage fallback
                const saved = localStorage.getItem(DICT_FILTERS_KEY);
                if (saved) {
                    const state = JSON.parse(saved);
                    search.value = state.search || '';
                    era.value = state.era || '';
                    region.value = state.region || '';
                    group.value = state.group || '';
                    sort.value = state.sort || 'kana';
                }
            };

            const updateFilterChips = () => {
                const chipContainer = document.querySelector('.filter-chips-container');
                const resetBtn = document.getElementById('filter-reset-btn');
                if (!chipContainer) return;
                
                let html = '';
                if (era.value) html += `<span class="filter-chip">${era.value}</span>`;
                if (region.value) html += `<span class="filter-chip">${region.value}</span>`;
                if (group.value) html += `<span class="filter-chip">${group.value}</span>`;
                if (!html) html = '<span style="font-size: 11px; color: var(--text-dim);">未設定</span>';
                
                chipContainer.innerHTML = html;

                // Toggle reset button visibility
                if (resetBtn) {
                    const hasActiveFilter = !!(era.value || region.value || group.value || search.value.trim() || sort.value !== 'kana');
                    resetBtn.style.display = hasActiveFilter ? 'inline-block' : 'none';
                }
            };

            const updateList = () => {
                const searchVal = search.value.trim().toLowerCase();
                const searchKata = hiraToKata(searchVal);
                const searchHira = kataToHira(searchVal);

                const eraVal = era.value;
                const regionVal = region.value;
                const groupVal = group.value;
                const sortVal = sort.value;

                // Save
                saveFiltersState();
                updateFilterChips();

                // UI Active States
                document.querySelectorAll('.timeline-era').forEach(t => {
                    t.classList.toggle('active', t.getAttribute('data-era') === eraVal);
                });
                document.querySelectorAll('.timeline-region').forEach(r => {
                    r.classList.toggle('active', r.getAttribute('data-region') === regionVal);
                });
                document.querySelectorAll('.timeline-group').forEach(g => {
                    g.classList.toggle('active', g.getAttribute('data-group') === groupVal);
                });

                // Filter & Sort
                cards.forEach(card => {
                    const name = card.getAttribute('data-name') || '';
                    const kana = card.getAttribute('data-kana') || '';
                    const id = card.getAttribute('data-id') || '';
                    const scientific = (card.getAttribute('data-scientific') || '').toLowerCase();
                    const cardEra = card.getAttribute('data-era') || '';
                    const cardRegion = card.getAttribute('data-region') || '';
                    const cardGroup = card.getAttribute('data-group') || '';

                    // Match Search
                    const matchesSearch = !searchVal || 
                        name.startsWith(searchKata) ||
                        kana.startsWith(searchHira) ||
                        id.includes(searchVal) ||
                        scientific.includes(searchVal);

                    // Match Era
                    const matchesEra = !eraVal || cardEra.includes(eraVal);

                    // Match Region
                    let matchesRegion = !regionVal;
                    if (regionVal) {
                        if (regionVal === '海洋') {
                            matchesRegion = cardRegion.includes('海') && !cardRegion.includes('北海道');
                        } else if (regionVal === 'アジア') {
                            matchesRegion = cardRegion.includes('アジア') && !cardRegion.includes('ロシア');
                        } else if (regionVal === 'オセアニア') {
                            matchesRegion = cardRegion.includes('オセアニア') || cardRegion.includes('オーストラリア');
                        } else {
                            matchesRegion = cardRegion.includes(regionVal);
                        }
                    }

                    // Match Group
                    let matchesGroup = !groupVal;
                    if (groupVal) {
                        if (groupVal === 'その他') {
                            const knownGroups = ['獣脚類', '竜脚類', '鳥脚類', '剣竜類', '堅頭竜類', 'よろい竜類', '角竜類', '翼竜', '首長竜', '魚竜'];
                            matchesGroup = !knownGroups.includes(cardGroup);
                        } else {
                            matchesGroup = cardGroup === groupVal;
                        }
                    }

                    if (matchesSearch && matchesEra && matchesRegion && matchesGroup) {
                        card.style.display = 'block';
                    } else {
                        card.style.display = 'none';
                    }
                });

                // Sort DOM elements
                const visibleCards = cards.filter(c => c.style.display !== 'none');
                if (sortVal === 'kana') {
                    visibleCards.sort((a, b) => {
                        const kanaA = a.getAttribute('data-kana') || '';
                        const kanaB = b.getAttribute('data-kana') || '';
                        return kanaA.localeCompare(kanaB, 'ja');
                    });
                } else if (sortVal === 'size') {
                    visibleCards.sort((a, b) => {
                        const lenA = extractNumber(a.getAttribute('data-length') || '');
                        const lenB = extractNumber(b.getAttribute('data-length') || '');
                        return lenB - lenA; // Big first
                    });
                }

                // Re-append in sorted order
                visibleCards.forEach(c => cardGrid.appendChild(c));
            };

            // Bind Events
            search.addEventListener('input', updateList);
            era.addEventListener('change', updateList);
            region.addEventListener('change', updateList);
            group.addEventListener('change', updateList);
            sort.addEventListener('change', updateList);

            // Timeline Click Binds
            document.querySelectorAll('.timeline-era').forEach(el => {
                el.addEventListener('click', () => {
                    era.value = el.getAttribute('data-era') || '';
                    updateList();
                });
            });
            document.querySelectorAll('.timeline-region').forEach(el => {
                el.addEventListener('click', () => {
                    region.value = el.getAttribute('data-region') || '';
                    updateList();
                });
            });
            document.querySelectorAll('.timeline-group').forEach(el => {
                el.addEventListener('click', () => {
                    group.value = el.getAttribute('data-group') || '';
                    updateList();
                });
            });

            // Accordion filter logic
            const accordionToggle = document.getElementById('filter-accordion-toggle');
            const accordionContent = document.getElementById('filter-accordion-content');
            const accordionLabel = document.getElementById('accordion-label');
            const accordionIcon = document.getElementById('accordion-icon');

            if (accordionToggle && accordionContent && accordionLabel && accordionIcon) {
                accordionToggle.addEventListener('click', (e) => {
                    const target = e.target as HTMLElement;
                    if (target.id === 'filter-reset-btn') {
                        return; // Bypass toggling accordion when clicking reset
                    }
                    const isHidden = accordionContent.style.display === 'none';
                    accordionContent.style.display = isHidden ? 'block' : 'none';
                    accordionLabel.innerText = isHidden ? 'フィルタを閉じる' : 'フィルタを展開';
                    accordionIcon.innerText = isHidden ? '[ - ]' : '[ + ]';
                    accordionToggle.style.borderColor = isHidden ? 'var(--primary-neon)' : 'var(--panel-border)';
                });
            }

            // Reset button logic
            const resetBtn = document.getElementById('filter-reset-btn');
            if (resetBtn) {
                resetBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    
                    // Reset all filters
                    era.value = '';
                    region.value = '';
                    group.value = '';
                    search.value = '';
                    sort.value = 'kana';
                    
                    // Trigger list update and save state
                    updateList();
                });
            }

            // Init load
            loadFiltersState();
            updateList();
        }

        // Run on load and transitions
        document.addEventListener('astro:page-load', initDictionary);
    </script>
</Layout>

<style>
    #filter-reset-btn:hover {
        border-color: #ff0055 !important;
        background: rgba(255, 0, 85, 0.15) !important;
        box-shadow: 0 0 10px rgba(255, 0, 85, 0.3);
        color: #ff0055 !important;
    }
</style>
