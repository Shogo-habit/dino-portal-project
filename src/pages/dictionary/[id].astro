---
import Layout from '../../layouts/Layout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import { REFERENCE_ASSETS } from '../../data/cyberAssets';
import { AUTHOR_DATA } from '../../data/author';
import { getCollection, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const dinosaurEntries = await getCollection('dinosaurs');
  return dinosaurEntries.map(entry => ({
    params: { id: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { data: d } = entry;
const { Content } = await render(entry);
const allDinosaurs = (await getCollection('dinosaurs')).map(entry => entry.data);

// FAQ Generation Logic for SEO/GEO
function generateDynamicFAQs(dino: any) {
    const faqs = [];
    if (dino.bioTraits && dino.bioTraits.length > 0) {
        const primaryTrait = dino.bioTraits[0];
        faqs.push({
            q: `${dino.name}の持つ「${primaryTrait.trait}」とはどのような能力ですか？`,
            a: `${primaryTrait.trait}は解析値で「${primaryTrait.value}」と評価されています。詳細は：${primaryTrait.detail}`
        });
    }
    faqs.push({
        q: `${dino.name}はどのような食性を持っていましたか？`,
        a: `${dino.name}は「${dino.diet}」でした。`
    });
    faqs.push({
        q: `${dino.name}はどこで、いつ頃生息していましたか？`,
        a: `${dino.era}の${dino.region}に生息していました。`
    });
    return faqs;
}

const faqs = generateDynamicFAQs(d);

// Generate JSON-LD schema specifically for this dinosaur
const taxonSchema = {
    "@context": "https://schema.org",
    "@type": "Taxon",
    "@id": `https://dino-portal.com/dictionary/${entry.id}/#taxon`,
    "name": d.name,
    "scientificName": d.scientificName,
    "taxonRank": d.group === "翼竜" ? "Order" : d.group === "首長竜" ? "Clade" : d.group === "魚竜" ? "Order" : "Genus",
    "description": d.description,
    "image": `https://dino-portal.com/${d.image}`
};

const schema = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Article",
            "headline": `${d.name} | Dino-Portal Specimen Analysis`,
            "description": `${d.name}（${d.scientificName}）の生物学的詳細データ。${d.description}`,
            "image": `https://dino-portal.com/${d.image}`,
            "author": {
                "@type": "Person",
                "name": AUTHOR_DATA.name,
                "jobTitle": AUTHOR_DATA.role,
                "description": AUTHOR_DATA.bio,
                "url": "https://dino-portal.com/"
            },
            "about": {
                "@id": `https://dino-portal.com/dictionary/${entry.id}/#taxon`
            }
        },
        taxonSchema,
        {
            "@type": "FAQPage",
            "mainEntity": faqs.map(f => ({
                "@type": "Question",
                "name": f.q,
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": f.a
                }
            }))
        }
    ]
};

// Size comparison rendering details
const PANEL_HEIGHT = 400;
const BASELINE_PX = 100;
const SAFE_ZONE_H = PANEL_HEIGHT - BASELINE_PX; // 300px
const SAFE_ZONE_W = 600;

const imagePath = path.join(process.cwd(), 'public', 'images', 'cyber', `${entry.id}.webp`);
const hasComparison = !!d.cyberMetadata && fs.existsSync(imagePath);
let dinoTotalH = 0;
let dinoBottomOffset = 0;
let refTotalH = 0;
let refBottomOffset = 0;
let dinoLeft = '15%';
let refRight = '15%';
let isLabelConflict = false;

// SVG座標系用 (viewBox 0 0 650 400)
let dinoW = 0;
let dinoH = 0;
let dinoX = 0;
let dinoY = 0;
let refW = 0;
let refH = 0;
let refX = 0;
let refY = 0;

const BASELINE_Y = 315; // SVG内でのベースラインのY座標 (400 - 85)

if (hasComparison) {
    const meta = d.cyberMetadata!;
    const realH = meta.realHeight || (parseFloat(d.length) * 0.35);
    const realL = meta.realLength || parseFloat(d.length);
    const ref = REFERENCE_ASSETS.HUMAN;

    // 1. セーフゾーンの高さ90%、幅85%以内に必ず収まる比率
    const maxPxPerMeterH = (SAFE_ZONE_H * 0.9) / realH;
    const maxPxPerMeterL = (SAFE_ZONE_W * 0.85) / realL;
    let pxPerMeter = Math.min(maxPxPerMeterH, maxPxPerMeterL);
    
    // zoomがある場合は乗算
    const zoom = meta.zoom || 1.0;
    pxPerMeter = pxPerMeter * zoom;
    
    // SVG化によりはみ出し見切れリスクが消滅したため、巨大恐竜のサイズを限界まで大きくできるよう
    // zoomが指定されている場合は、absoluteMaxH や absoluteMaxL による安全制限クランプを完全にバイパスします！
    const absoluteMaxH = meta.zoom ? 999 : (SAFE_ZONE_H * 0.95) / realH;
    const absoluteMaxL = meta.zoom ? 999 : (SAFE_ZONE_W * 0.98) / realL;
    pxPerMeter = Math.min(pxPerMeter, absoluteMaxH, absoluteMaxL);

    // 小さい生物用の最小縮尺調整 (人間が巨大化しすぎるのを防ぐ)
    if (realH < ref.realHeight) {
        const humanTargetH = SAFE_ZONE_H * 0.85;
        pxPerMeter = Math.min(pxPerMeter, humanTargetH / ref.realHeight);
    }
    
    // 2. 配置位置の決定
    const dinoDrawW = realL * pxPerMeter;
    let leftPercent = 15;
    let rightPercent = 15;
    
    if (dinoDrawW > 350) {
        leftPercent = 5;
        rightPercent = 5;
    } else if (dinoDrawW > 250) {
        leftPercent = 10;
        rightPercent = 10;
    }
    
    // 個別指定値（meta.dinoLeft）があればそれを基準とする
    const finalLeftPercent = meta.dinoLeft ? parseFloat(meta.dinoLeft) : leftPercent;
    const finalRightPercent = meta.refRight ? parseFloat(meta.refRight) : rightPercent;
    
    dinoLeft = `${finalLeftPercent}%`;
    refRight = `${finalRightPercent}%`;

    // 3. SVG用の絶対座標の精密計算 (中央揃えからの変換)
    const dinoScale = (pxPerMeter * realH) / meta.contentHeightPx;
    dinoW = meta.sourceRes * dinoScale;
    dinoH = meta.sourceRes * dinoScale;
    const dinoBottomGapPx = meta.bottomGap * dinoScale;
    
    dinoX = (650 * finalLeftPercent / 100);
    dinoY = BASELINE_Y - dinoH + dinoBottomGapPx;

    const refTargetH = ref.realHeight * pxPerMeter;
    const refScale = refTargetH / ref.contentHeightPx;
    refW = ref.sourceRes * refScale;
    refH = ref.sourceRes * refScale;
    const refBottomGapPx = ref.bottomGap * refScale;

    refX = 650 - (650 * finalRightPercent / 100) - refW;
    refY = BASELINE_Y - refH + refBottomGapPx;

    // 4. 実座標ベースの衝突判定
    const dinoTagX = dinoX + dinoW / 2;
    const refTagX = refX + refW / 2;
    // タグの合計横幅が 210/2 + 110/2 = 160px。マージンを入れて180px以内の接近で重なりと判定。
    if (Math.abs(dinoTagX - refTagX) < 180) {
        isLabelConflict = true;
    }
}

const formatVal = (val: number) => val % 1 === 0 ? val.toFixed(1) : val.toString();

// Find related specimens
const eras = ["白亜紀", "ジュラ紀", "三畳紀", "古生代"];
const currentEraBase = eras.find(e => d.era.includes(e));
const relatedSpecimens = allDinosaurs.filter(item => {
    if (item.id === d.id) return false;
    const matchesGroup = item.group === d.group;
    const matchesEra = currentEraBase && item.era.includes(currentEraBase);
    const matchesRegion = item.region === d.region;
    return matchesGroup || matchesEra || matchesRegion;
}).slice(0, 4);

const topics = await getCollection('topics');
const relatedTopics = topics
    .map(entry => entry.data)
    .filter(t => t.relatedSpecimens && t.relatedSpecimens.includes(d.id))
    .sort((a, b) => b.date.localeCompare(a.date))
    .slice(0, 3);
---

<Layout title={`${d.name} | Specimen Analysis | Dino-Portal`} activeTab="dictionary" description={`${d.name} (${d.scientificName}) の生物学的特性、出現年代、生息地、サイズ比較スケールデータ。`} ogImage={`/${d.image}`} schema={schema}>
    <article class={`detail-layout ${!hasComparison ? 'no-comparison' : ''}`}>
        <!-- 左カラム (ビジュアル系) -->
        <div class="detail-visual-column">
            <!-- 2. メインイラスト (visual) -->
            <div class="detail-main-visual" style="width: 100%;">
                {d.gallery && d.gallery.length > 0 ? (
                    <div class="detail-img-viewer hud-panel slider-panel" style="margin-bottom: 30px; position: relative;">
                        <div class="hud-corner top-left"></div>
                        <div class="hud-corner bottom-right"></div>
                        <div class="scan-line-ani" style="pointer-events: none;"></div>
                        
                        <div class="slider-container" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; overflow: hidden;">
                            <div class="slider-track" id="dino-slider" style="display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; -webkit-overflow-scrolling: touch; scrollbar-width: none; width: 100%; height: 100%;">
                                <div class="slider-slide" style="flex: 0 0 100%; width: 100%; min-width: 100%; max-width: 100%; height: 100%; scroll-snap-align: start; display: flex; justify-content: center; align-items: center;">
                                    <img src={`/${d.image}`} alt={d.name} fetchpriority="high" decoding="async" width="800" height="533" style="width: 100%; height: 100%; object-fit: contain; filter: drop-shadow(0 0 30px rgba(0,242,255,0.3));">
                                </div>
                                {d.gallery.map((imgUrl, idx) => (
                                    <div class="slider-slide" style="flex: 0 0 100%; width: 100%; min-width: 100%; max-width: 100%; height: 100%; scroll-snap-align: start; display: flex; justify-content: center; align-items: center;">
                                        <img src={`/${imgUrl}`} alt={`${d.name} イラスト ${idx + 2}`} loading="lazy" decoding="async" width="800" height="533" style="width: 100%; height: 100%; object-fit: contain; filter: drop-shadow(0 0 30px rgba(0,242,255,0.3));">
                                    </div>
                                ))}
                            </div>
                        </div>

                        <!-- Pagination Dots -->
                        <div class="slider-dots" style="position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 10;">
                            <span class="slider-dot active" data-index="0" style="width: 8px; height: 8px; border-radius: 50%; background: var(--primary-neon); border: 1px solid var(--primary-neon); cursor: pointer; transition: all 0.3s ease; box-shadow: 0 0 8px var(--primary-neon);"></span>
                            {d.gallery.map((_, idx) => (
                                <span class="slider-dot" data-index={idx + 1} style="width: 8px; height: 8px; border-radius: 50%; background: rgba(0, 242, 255, 0.25); border: 1px solid var(--primary-neon); cursor: pointer; transition: all 0.3s ease;"></span>
                            ))}
                        </div>

                        <div style="position: absolute; bottom: 10px; right: 10px; font-family: var(--font-mono); font-size: 10px; color: var(--primary-neon); z-index: 10; pointer-events: none;">
                            IMG_SEC_ENCRYPTED: {d.id.toUpperCase()}
                        </div>
                    </div>
                ) : (
                    <div class="detail-img-viewer hud-panel" style="margin-bottom: 30px;">
                        <div class="hud-corner top-left"></div>
                        <div class="hud-corner bottom-right"></div>
                        <div class="scan-line-ani"></div>
                        <img src={`/${d.image}`} alt={d.name} fetchpriority="high" decoding="async" width="800" height="533" style="width: 100%; height: 100%; object-fit: contain;">
                        <div style="position: absolute; bottom: 10px; right: 10px; font-family: var(--font-mono); font-size: 10px; color: var(--primary-neon);">
                            IMG_SEC_ENCRYPTED: {d.id.toUpperCase()}
                        </div>
                    </div>
                )}
            </div>

            <!-- 5. サイズ比較パネル (comparison) -->
            {hasComparison && (
                <div class="detail-comparison" style="width: 100%; max-width: 100%; min-width: 0;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; padding: 0 5px; flex-wrap: wrap; gap: 10px;">
                        <h4 style="color: var(--primary-neon); margin: 0; white-space: nowrap;">サイズ比較</h4>
                        <a href="/size-comparison/" style="font-size: 11px; color: var(--secondary-neon); text-decoration: none; font-family: var(--font-mono); font-weight: bold; transition: opacity 0.3s; white-space: normal; text-align: right;">
                            [ シミュレータで他と比較する ] &raquo;
                        </a>
                    </div>
                    
                    <div class="size-comparison-panel hud-panel" style="width: 100%; max-width: 100%; height: auto !important; aspect-ratio: 650/400; padding: 0; overflow: hidden; border: 1px solid var(--panel-border); background: radial-gradient(circle at center, rgba(0, 40, 60, 0.4) 0%, rgba(0, 0, 0, 0.8) 100%);">
                        <svg viewBox="0 0 650 400" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" style="display: block; overflow: visible;">
                            <defs>
                                <pattern id="hud-grid-minor" width="20" height="20" patternUnits="userSpaceOnUse">
                                    <path d="M 20 0 L 0 0 0 20" fill="none" stroke="rgba(0, 242, 255, 0.04)" stroke-width="1"/>
                                </pattern>
                                <pattern id="hud-grid-major" width="100" height="100" patternUnits="userSpaceOnUse">
                                    <path d="M 100 0 L 0 0 0 100" fill="none" stroke="rgba(0, 242, 255, 0.15)" stroke-width="1.5"/>
                                </pattern>
                            </defs>
                            
                            <!-- grid patterns -->
                            <rect width="650" height="400" fill="url(#hud-grid-minor)" />
                            <rect width="650" height="400" fill="url(#hud-grid-major)" />
                            
                            <!-- baseline -->
                            <line x1="0" y1="315" x2="650" y2="315" stroke="rgba(0, 242, 255, 0.3)" stroke-width="1.5" stroke-dasharray="4,4" />
                            
                            <!-- Dino visual -->
                            <image href={`/images/cyber/${d.id}.webp`} x={dinoX} y={dinoY} width={dinoW} height={dinoH} style="mix-blend-mode: screen;" />
                            
                            <!-- Human reference -->
                            <image href="/images/cyber/human_front.webp" x={refX} y={refY} width={refW} height={refH} style="mix-blend-mode: screen;" />
                            
                            <!-- Dino Tag -->
                            <g transform={`translate(${dinoX + dinoW/2}, ${isLabelConflict ? 377 : 350})`}>
                                <rect x="-105" y="-12" width="210" height="30" fill="rgba(0, 10, 20, 0.75)" stroke="rgba(0, 242, 255, 0.25)" stroke-width="1" rx="3" />
                                <line x1="0" y1="-25" x2="0" y2="-12" stroke="rgba(0, 242, 255, 0.2)" stroke-width="1" stroke-dasharray="2,2" />
                                <text text-anchor="middle" fill="#00f2ff" font-size="11.5" font-family="var(--font-mono)" font-weight="bold">{d.name}</text>
                                <text text-anchor="middle" fill="#00f2ff" font-size="9" opacity="0.8" font-family="var(--font-mono)" y="13">
                                    高さ {formatVal(d.cyberMetadata?.realHeight || 0)}m（全長 {d.length}）
                                </text>
                            </g>
                            
                            <!-- Human Tag -->
                            <g transform={`translate(${refX + refW/2}, 350)`}>
                                <rect x="-55" y="-12" width="110" height="30" fill="rgba(0, 10, 20, 0.75)" stroke="rgba(0, 242, 255, 0.25)" stroke-width="1" rx="3" />
                                <line x1="0" y1="-25" x2="0" y2="-12" stroke="rgba(0, 242, 255, 0.2)" stroke-width="1" stroke-dasharray="2,2" />
                                <text text-anchor="middle" fill="#00f2ff" font-size="11.5" font-family="var(--font-mono)" font-weight="bold">人間</text>
                                <text text-anchor="middle" fill="#00f2ff" font-size="9" opacity="0.8" font-family="var(--font-mono)" y="13">高さ 1.7m</text>
                            </g>
                        </svg>
                    </div>
                </div>
            )}
        </div>

        <!-- 右カラム (テキストデータ系) -->
        <div class="detail-data">
            <!-- 1. 恐竜名 & 学名 & 保存ボタン (header) -->
            <header class="detail-header">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 20px; flex-wrap: wrap;">
                    <div>
                        <h1 class="detail-title">{d.name}</h1>
                        <p class="detail-scientific">[ {d.scientificName} ]</p>
                    </div>
                    <button class="save-btn" id="observe-save-btn" aria-label="図鑑に保存" data-id={d.id}>
                        + 観測データに保存
                    </button>
                </div>
            </header>

            <!-- 3. 解説 (body) -->
            <div class="detail-content-body">
                <section class="hud-panel" style="margin-bottom: 30px;">
                    <p style="line-height: 1.8; font-size: 14px;">{d.description}</p>
                </section>

                <section class="hud-panel" style="margin-bottom: 30px; padding: 25px; border-color: rgba(0, 242, 255, 0.15); position: relative;">
                    <div class="hud-corner top-left" style="border-top-color: rgba(0, 242, 255, 0.3); border-left-color: rgba(0, 242, 255, 0.3);"></div>
                    <div class="hud-corner bottom-right" style="border-bottom-color: rgba(0, 242, 255, 0.3); border-right-color: rgba(0, 242, 255, 0.3);"></div>
                    <h4 style="border-bottom: 1px solid var(--panel-border); padding-bottom: 10px; margin-bottom: 15px; color: var(--primary-neon); font-size: 14px; font-family: var(--font-mono); letter-spacing: 1px;">
                        [ 詳細解説 ]
                    </h4>
                    <div class="archival-content" style="line-height: 1.9; font-size: 14px; color: var(--text-main); text-align: justify;">
                        <Content />
                    </div>
                </section>
            </div>

            <!-- 4. 統合スペック・特性解析パネル (specs-traits-integrated) -->
            <div class="detail-specs-integrated" style="margin-top: 25px;">
                <section class="hud-panel" style="padding: 20px; border-color: rgba(0, 242, 255, 0.2); position: relative; background: rgba(0, 242, 255, 0.01);">
                    <div class="hud-corner top-left" style="border-top-color: rgba(0, 242, 255, 0.35); border-left-color: rgba(0, 242, 255, 0.35);"></div>
                    <div class="hud-corner bottom-right" style="border-bottom-color: rgba(0, 242, 255, 0.35); border-right-color: rgba(0, 242, 255, 0.35);"></div>
                    
                    <h4 style="border-bottom: 1px solid var(--panel-border); padding-bottom: 8px; margin-bottom: 15px; color: var(--primary-neon); font-size: 14px; font-weight: bold; letter-spacing: 1px;">
                        [ 基本スペック ]
                    </h4>

                    <!-- 基本データグリッド (6項目: 年代, 生息地域, 分類, 食性, 全長, 推定体重) -->
                    <div class="spec-panel" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 0; margin-bottom: 20px;">
                        <div class="spec-item" style="border-color: rgba(0, 242, 255, 0.1); background: rgba(1, 10, 18, 0.6);"><span class="spec-label">生息年代</span><br>{d.era}</div>
                        <div class="spec-item" style="border-color: rgba(0, 242, 255, 0.1); background: rgba(1, 10, 18, 0.6);"><span class="spec-label">生息地域</span><br>{d.region}</div>
                        <div class="spec-item" style="border-color: rgba(0, 242, 255, 0.1); background: rgba(1, 10, 18, 0.6);"><span class="spec-label">分類</span><br>{d.group}</div>
                        <div class="spec-item" style="border-color: rgba(0, 242, 255, 0.1); background: rgba(1, 10, 18, 0.6);"><span class="spec-label">食性</span><br>{d.diet}</div>
                        <div class="spec-item" style="border-color: rgba(0, 242, 255, 0.1); background: rgba(1, 10, 18, 0.6);"><span class="spec-label">全長</span><br>{d.length}</div>
                        <div class="spec-item" style="border-color: rgba(0, 242, 255, 0.1); background: rgba(1, 10, 18, 0.6);"><span class="spec-label">推定体重</span><br>{d.weight}</div>
                    </div>

                    <!-- 生物学的特性解析 -->
                    {d.bioTraits && d.bioTraits.length > 0 && (
                        <div class="trait-bar-wrap" style="margin-top: 0; border-top: 1px dashed rgba(0, 242, 255, 0.15); padding-top: 15px;">
                            <h5 style="color: var(--primary-neon); margin-bottom: 12px; font-family: var(--font-mono); font-size: 14px; font-weight: bold; letter-spacing: 1px;">[ 特徴 ]</h5>
                            <div style="display: flex; flex-direction: column; gap: 12px;">
                                {d.bioTraits.map(t => (
                                    <div class="trait-row" style="margin-bottom: 0;">
                                        <div style="font-size: 13px; line-height: 1.6; color: var(--text-main); text-align: justify;">
                                            <strong style="color: var(--primary-neon); font-family: var(--font-mono); margin-right: 6px;">
                                                {t.trait}
                                            </strong>
                                            <span style="color: var(--text-dim); margin-right: 6px;">:</span>
                                            <span style="color: var(--text-main);">{t.detail}</span>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    )}
                </section>
            </div>

            <!-- 6. その他 (traits & FAQ) -->
            <div class="detail-traits">

                <!-- Dynamic FAQ Section for GEO -->
                <div class="geo-faq-section" style="margin-top: 30px;" itemscope itemtype="https://schema.org/FAQPage">
                    <h4 style="color: var(--primary-neon); margin-bottom: 15px;">よくある質問と回答 (FAQ)</h4>
                    {faqs.map((faq, idx) => (
                        <details class="faq-item hud-panel" open={idx === 0} style="margin-bottom: 10px;" itemprop="mainEntity" itemscope itemtype="https://schema.org/Question">
                            <summary class="faq-summary" style="cursor: pointer; padding: 10px; color: var(--primary-neon); font-weight: bold;" itemprop="name">{faq.q}</summary>
                            <div class="faq-content" style="padding: 10px; line-height: 1.6; border-top: 1px solid var(--panel-border);" itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                                <span itemprop="text">{faq.a}</span>
                            </div>
                        </details>
                    ))}
                </div>
                
                <div style="margin-top: 40px; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--panel-border); padding-top: 20px; gap: 20px; flex-wrap: wrap;">
                    <a href="/dictionary/" class="nav-link" aria-label="アーカイブ一覧に戻る" style="text-decoration: none;">[ アーカイブに戻る ]</a>
                    
                    <div class="feedback-container" id="feedback-detail" style="display: flex; align-items: center; gap: 10px;">
                        <span style="font-size: 11px; color: var(--text-dim); font-family: var(--font-mono);">
                            期待したデータは得られましたか？
                        </span>
                        <button class="feedback-btn" id="feedback-yes" aria-label="はい">YES</button>
                        <button class="feedback-btn" id="feedback-no" aria-label="いいえ">NO</button>
                        <div class="feedback-msg" id="msg-detail" style="font-size: 11px; color: var(--secondary-neon); font-family: var(--font-mono); opacity: 0; transition: opacity 0.3s ease; position: absolute; margin-top: 25px;"></div>
                    </div>
                </div>

                <!-- Scientific References Section (E-E-A-T) -->
                {d.references && d.references.length > 0 && (
                    <section class="references-panel hud-panel" style="margin-top: 40px; padding: 25px; border-color: rgba(0, 242, 255, 0.15); position: relative;">
                        <div class="hud-corner top-left" style="border-top-color: rgba(0, 242, 255, 0.3); border-left-color: rgba(0, 242, 255, 0.3);"></div>
                        <div class="hud-corner bottom-right" style="border-bottom-color: rgba(0, 242, 255, 0.3); border-right-color: rgba(0, 242, 255, 0.3);"></div>
                        <h4 style="border-bottom: 1px solid var(--panel-border); padding-bottom: 10px; margin-bottom: 15px; color: var(--primary-neon); font-size: 14px; font-family: var(--font-mono); letter-spacing: 1px;">
                            [ 学術参考文献 ]
                        </h4>
                        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;">
                            {d.references.map((ref: any) => (
                                <li style="border-left: 2px solid var(--primary-neon); padding-left: 15px;">
                                    <div style="font-weight: bold; color: var(--text-main); font-size: 14px;">{ref.title}</div>
                                    <div style="font-size: 12px; color: var(--text-dim); margin-top: 4px;">
                                        <span>{ref.journal}</span> &bull; <span>{ref.year}</span>
                                    </div>
                                    <a href={ref.url} target="_blank" rel="noopener noreferrer" style="display: inline-block; font-size: 11px; color: var(--primary-neon); text-decoration: none; margin-top: 6px; font-family: var(--font-mono);">
                                        [ 論文・文献リンク ] &raquo;
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </section>
                )}

                <!-- Related Topics Section -->
                {relatedTopics.length > 0 && (
                    <section class="related-topics" style="margin-top: 40px; border-top: 1px solid var(--panel-border); padding-top: 30px;">
                        <h3 class="related-title" style="font-family: var(--font-mono); font-size: 14px; color: var(--primary-neon); margin-bottom: 20px; letter-spacing: 1px;">
                            [ 関連する特集・記事 ]
                        </h3>
                        <div class="topics-simple-list" style="display: flex; flex-direction: column; gap: 15px;">
                            {relatedTopics.map(t => (
                                <a href={`/topics/${t.id}/`} style="text-decoration: none; color: inherit; display: block;">
                                    <div class="related-topic-card hud-panel" style="cursor: pointer; display: flex; gap: 15px; align-items: center; padding: 15px; border-color: rgba(0, 242, 255, 0.15); transition: all 0.3s ease;">
                                        <div class="topic-mini-thumb" style="width: 80px; height: 50px; flex-shrink: 0; background-color: #000; border: 1px solid var(--panel-border); overflow: hidden;">
                                            <img src={`/${t.image}`} alt={t.title} width="80" height="50" loading="lazy" decoding="async" style="width: 100%; height: 100%; object-fit: cover;">
                                        </div>
                                        <div style="flex: 1;">
                                            <div style="font-size: 10px; color: var(--primary-neon); font-family: var(--font-mono); margin-bottom: 3px;">
                                                {t.date} | {t.category}
                                            </div>
                                            <h4 style="font-size: 14px; margin: 0; color: var(--text-main); font-weight: 500;">{t.title}</h4>
                                        </div>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </section>
                )}

                <!-- Related Specimens Section -->
                {relatedSpecimens.length > 0 && (
                    <section class="related-specimens" style="margin-top: 60px;">
                        <h3 class="related-title" style="border-bottom: 1px solid var(--panel-border); padding-bottom: 10px; margin-bottom: 20px;">
                            関連する標本データ (時代/地域に基づく選出)
                        </h3>
                        <div class="related-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 15px;">
                            {relatedSpecimens.map(item => (
                                <a href={`/dictionary/${item.id}/`} style="text-decoration: none; color: inherit;">
                                    <div class="related-card hud-panel" style="cursor: pointer; height: 100%;">
                                        <div class="related-img-wrap" style="width: 100%; height: auto; aspect-ratio: 4/3; overflow: hidden; position: relative; background: #000;">
                                            <img src={`/${item.image}`} alt={item.name} width="160" height="120" loading="lazy" decoding="async" style="width: 100%; height: 100%; display: block; object-fit: cover;">
                                        </div>
                                        <h4 class="related-name" style="font-size: 12px; margin: 8px 0 4px 0; color: var(--text-main);">{item.name}</h4>
                                        <div class="related-meta" style="font-size: 9px; color: var(--text-dim);">{item.era} / {item.region}</div>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </section>
                )}
            </div>
        </div>
    </article>

    <!-- Affiliate Product recommendation section -->
    <AffiliateSection dinoId={d.id} />

    <!-- Client-side logic for observed savings & feedback -->
    <script>
        const COLLECTION_KEY = 'dino_portal_saved_observations';

        function initSpecimenDetail() {
            const saveBtn = document.getElementById('observe-save-btn');
            if (!saveBtn) return;

            const dinoId = saveBtn.getAttribute('data-id');
            if (!dinoId) return;

            // Load observed state
            const getCollection = () => {
                const saved = localStorage.getItem(COLLECTION_KEY);
                return saved ? JSON.parse(saved) : [];
            };

            const toggleCollection = (id: string) => {
                let current = getCollection();
                if (current.includes(id)) {
                    current = current.filter((item: string) => item !== id);
                } else {
                    current.push(id);
                }
                localStorage.setItem(COLLECTION_KEY, JSON.stringify(current));
                return current.includes(id);
            };

            const updateButtonState = (isSaved: boolean) => {
                saveBtn.classList.toggle('saved', isSaved);
                saveBtn.innerHTML = isSaved ? '✓ 観測データ保存済み' : '+ 観測データに保存';
            };

            // Initial button display
            const initialList = getCollection();
            updateButtonState(initialList.includes(dinoId));

            // Bind click
            saveBtn.addEventListener('click', () => {
                const isSaved = toggleCollection(dinoId);
                updateButtonState(isSaved);
            });

            // Feedback controls logic
            const yesBtn = document.getElementById('feedback-yes');
            const noBtn = document.getElementById('feedback-no');
            const msgEl = document.getElementById('msg-detail');

            if (yesBtn && noBtn && msgEl) {
                const showFeedbackMessage = (isPositive: boolean) => {
                    msgEl.innerText = isPositive 
                        ? "> フィードバック受理: 期待値との完全な同期を確認。" 
                        : "> フィードバック受理: 解析精度の再調整を要求中。";
                    msgEl.style.opacity = '1';
                    setTimeout(() => {
                        msgEl.style.opacity = '0';
                    }, 3000);
                };

                yesBtn.addEventListener('click', () => showFeedbackMessage(true));
                noBtn.addEventListener('click', () => showFeedbackMessage(false));
            }
        }

        function initSpecimenSlider() {
            const track = document.getElementById('dino-slider');
            const dots = document.querySelectorAll('.slider-dot');
            if (!track || dots.length === 0) return;

            const updateActiveDot = () => {
                const scrollLeft = track.scrollLeft;
                const width = track.clientWidth;
                const activeIndex = Math.round(scrollLeft / width);

                dots.forEach((dot, idx) => {
                    if (dot instanceof HTMLElement) {
                        if (idx === activeIndex) {
                            dot.classList.add('active');
                            dot.style.background = 'var(--primary-neon)';
                            dot.style.boxShadow = '0 0 8px var(--primary-neon)';
                        } else {
                            dot.classList.remove('active');
                            dot.style.background = 'rgba(0, 242, 255, 0.25)';
                            dot.style.boxShadow = 'none';
                        }
                    }
                });
            };

            track.addEventListener('scroll', updateActiveDot);

            dots.forEach((dot) => {
                dot.addEventListener('click', (e) => {
                    const target = e.target;
                    if (target instanceof HTMLElement) {
                        const index = parseInt(target.getAttribute('data-index') || '0', 10);
                        const width = track.clientWidth;
                        track.scrollTo({
                            left: index * width,
                            behavior: 'smooth'
                        });
                    }
                });
            });

            // Handle window resizing
            window.addEventListener('resize', updateActiveDot);
            
            // Set initial state
            updateActiveDot();
        }

        // Bind on page load / page changes
        document.addEventListener('astro:page-load', () => {
            initSpecimenDetail();
            initSpecimenSlider();
        });
    </script>
</Layout>

<style>
  .related-topic-card:hover {
    border-color: var(--primary-neon) !important;
    box-shadow: 0 0 15px rgba(0, 242, 255, 0.2);
    background: rgba(0, 242, 255, 0.05) !important;
  }

  /* Slider UI styles */
  .slider-panel {
    overflow: hidden;
  }
  
  .slider-track {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .slider-track::-webkit-scrollbar {
    display: none;
  }

  /* Constrain images in slides to match original 100% footprint and shadow */
  .slider-slide img {
    width: 100% !important;
    height: 100% !important;
    max-width: 100% !important;
    max-height: 100% !important;
    object-fit: contain;
    filter: drop-shadow(0 0 30px rgba(0, 242, 255, 0.3));
  }
</style>
