---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { AUTHOR_DATA } from '../data/author';

const dinosaurs = await getCollection('dinosaurs');
// Choose a random dinosaur at build time (beneficial for SEO/GEO crawlers indexing unique keywords on each build)
const randomIndex = Math.floor(Math.random() * dinosaurs.length);
const pickupDino = dinosaurs[randomIndex].data;

const topics = await getCollection('topics');
const topicItems = topics
  .map(entry => entry.data)
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 2);

const recentlyAddedIds = ['australovenator', 'leaellynasaura', 'savannasaurus'];
const recentlyAddedDinos = dinosaurs
  .filter(d => recentlyAddedIds.includes(d.id))
  .map(d => d.data);
---

<Layout title="ホーム | Dino-Portal" activeTab="home" description="Dino-Portalのメインコンソール。最新の古生物学的発見と本日のピックアップデータ。" ogImage="/images/cyber_world_map.webp">
    <section class="page-header">
      <h2 class="page-title">ホーム</h2>
    </section>

    <div class="home-layout">
        <div class="home-main-column">
            <div class="dino-day-hero hud-panel">
                <div class="hud-corner top-left"></div>
                <div class="hud-corner bottom-right"></div>
                <div class="hero-img-container" style={`background-image: url('/${pickupDino.image}')`}></div>
                <div class="hero-content">
                    <span class="hero-label">【本日のピックアップ】</span>
                    <h3 class="hero-name" style="font-size: 32px; margin: 10px 0;">{pickupDino.name}</h3>
                    <p class="hero-desc" style="color: var(--text-dim); line-height: 1.6; margin-bottom: 20px;">{pickupDino.description}</p>
                    <a href={`/dictionary/${pickupDino.id}/`} class="nav-link" style="display: inline-block; width: fit-content; text-decoration: none;">詳細データを閲覧</a>
                </div>
            </div>

            <div class="category-tag-scan hud-panel">
                <h4 style="margin-bottom: 20px; border-bottom: 1px solid var(--panel-border); padding-bottom: 10px;">分類スキャン (TAG CLOUD)</h4>
                
                <div style="margin-bottom: 20px;">
                    <span style="font-size: 11px; color: var(--primary-neon); font-family: var(--font-mono); display: block; margin-bottom: 8px;">[ 年代別セクター / TEMPORAL SECTOR ]</span>
                    <div class="tag-group" style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <a href="/dictionary/?era=白亜紀" class="scan-tag-btn">白亜紀</a>
                        <a href="/dictionary/?era=ジュラ紀" class="scan-tag-btn">ジュラ紀</a>
                        <a href="/dictionary/?era=三畳紀" class="scan-tag-btn">三畳紀</a>
                    </div>
                </div>

                <div style="margin-bottom: 20px;">
                    <span style="font-size: 11px; color: var(--primary-neon); font-family: var(--font-mono); display: block; margin-bottom: 8px;">[ 主要系統グループ / SYSTEMATIC GROUP ]</span>
                    <div class="tag-group" style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <a href="/dictionary/?group=獣脚類" class="scan-tag-btn">獣脚類</a>
                        <a href="/dictionary/?group=竜脚類" class="scan-tag-btn">竜脚類</a>
                        <a href="/dictionary/?group=鳥脚類" class="scan-tag-btn">鳥脚類</a>
                        <a href="/dictionary/?group=角竜類" class="scan-tag-btn">角竜類</a>
                        <a href="/dictionary/?group=よろい竜類" class="scan-tag-btn">よろい竜類</a>
                        <a href="/dictionary/?group=剣竜類" class="scan-tag-btn">剣竜類</a>
                    </div>
                </div>

                <div>
                    <span style="font-size: 11px; color: var(--primary-neon); font-family: var(--font-mono); display: block; margin-bottom: 8px;">[ 発掘セクター地域 / SPATIAL REGION ]</span>
                    <div class="tag-group" style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <a href="/dictionary/?region=北アメリカ" class="scan-tag-btn">北アメリカ</a>
                        <a href="/dictionary/?region=アジア" class="scan-tag-btn">アジア</a>
                        <a href="/dictionary/?region=ヨーロッパ" class="scan-tag-btn">ヨーロッパ</a>
                        <a href="/dictionary/?region=日本" class="scan-tag-btn">日本</a>
                        <a href="/dictionary/?region=オセアニア" class="scan-tag-btn">オセアニア</a>
                    </div>
                </div>
            </div>

            <div class="author-summary hud-panel">
                <h4 style="margin-bottom: 20px; border-bottom: 1px solid var(--panel-border); padding-bottom: 10px;">キュレーター情報</h4>
                <div class="author-profile-card">
                    <div class="author-header">
                        <div class="author-avatar">
                            <img src="/images/plofile/profile_image.webp" alt="Dino-Portal キュレーター" />
                        </div>
                        <div class="author-meta">
                            <span class="author-name">{AUTHOR_DATA.name}</span>
                            <span class="author-title">{AUTHOR_DATA.role}</span>
                        </div>
                    </div>
                    <p class="author-bio">{AUTHOR_DATA.bio}</p>
                    <div style="text-align: right;">
                        <a href="/about/" style="font-size: 12px; color: var(--primary-neon); text-decoration: none; font-family: var(--font-mono);">[ プロフィール詳細へ ]</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="home-sidebar-column">
            <div class="news-summary-sidebar hud-panel">
                <h4 style="margin-bottom: 20px; border-bottom: 1px solid var(--panel-border); padding-bottom: 10px;">最新トピックス</h4>
                {topicItems.map(item => (
                    <a href={`/topics/${item.id}/`} class="news-item-link">
                        <div class="news-item-img-wrap">
                            <img src={`/${item.image}`} alt={item.title} loading="lazy" decoding="async" />
                            <div class="scanline-overlay"></div>
                        </div>
                        <div class="news-item-meta">
                            <span class="news-item-date">{item.date}</span>
                            <span class="news-item-badge">{item.category}</span>
                        </div>
                        <h5 class="news-item-title">{item.title}</h5>
                        <p class="news-item-summary">{item.summary.slice(0, 50)}...</p>
                    </a>
                ))}
                <a href="/topics/" style="font-size: 12px; color: var(--primary-neon); text-decoration: none;">[ トピックス一覧にアクセス ]</a>
            </div>

            <div class="recent-dinosaurs-sidebar hud-panel">
                <h4 style="margin-bottom: 20px; border-bottom: 1px solid var(--panel-border); padding-bottom: 10px;">最近追加した恐竜</h4>
                <div class="recent-dinos-list" style="display: flex; flex-direction: column; gap: 20px;">
                    {recentlyAddedDinos.map(dino => (
                        <a href={`/dictionary/${dino.id}/`} class="recent-dino-item-link" style="text-decoration: none; color: inherit; display: block;">
                            <div class="recent-dino-card" style="display: flex; gap: 15px; align-items: center; padding: 10px; border: 1px solid var(--panel-border); background: rgba(4, 8, 12, 0.4); transition: all 0.3s ease; position: relative; overflow: hidden;">
                                <div class="recent-dino-thumb" style="width: 70px; height: 70px; flex-shrink: 0; border: 1px solid var(--panel-border); overflow: hidden; background: #000;">
                                    <img src={`/${dino.image}`} alt={dino.name} style="width: 100%; height: 100%; object-fit: cover;" />
                                </div>
                                <div style="flex: 1; min-width: 0;">
                                    <h5 style="margin: 0 0 5px 0; font-size: 14px; color: var(--text-main); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{dino.name}</h5>
                                    <div style="font-size: 10px; color: var(--primary-neon); font-family: var(--font-mono); margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                        {dino.scientificName}
                                    </div>
                                    <div style="font-size: 11px; color: var(--text-dim);">
                                        {dino.era} / {dino.region}
                                    </div>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
                <div style="margin-top: 20px;">
                    <a href="/dictionary/" style="font-size: 12px; color: var(--primary-neon); text-decoration: none;">[ 図鑑アーカイブ一覧 ]</a>
                </div>
            </div>
        </div>
    </div>
    </div>
</Layout>

<style>
  .news-item-link {
    display: block;
    text-decoration: none;
    color: inherit;
    margin-bottom: 25px;
  }

  .news-item-img-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--panel-border);
    margin-bottom: 10px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .news-item-img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .news-item-link:hover .news-item-img-wrap {
    border-color: var(--primary-neon);
    box-shadow: 0 0 15px rgba(0, 242, 255, 0.25);
  }

  .news-item-link:hover .news-item-img-wrap img {
    transform: scale(1.05);
  }

  .scanline-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(0, 242, 255, 0.15) 100%);
    pointer-events: none;
  }

  .news-item-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .news-item-date {
    font-size: 10px;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }

  .news-item-badge {
    font-size: 9px;
    font-family: var(--font-mono);
    color: var(--primary-neon);
    background: rgba(0, 242, 255, 0.1);
    border: 1px solid var(--primary-neon);
    padding: 2px 6px;
    text-transform: uppercase;
  }

  .news-item-title {
    margin: 0 0 8px 0;
    font-size: 14px;
    line-height: 1.4;
    color: var(--text-main);
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .news-item-link:hover .news-item-title {
    color: var(--primary-neon);
  }

  .news-item-summary {
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
    margin: 0;
  }

  .recent-dino-item-link:hover .recent-dino-card {
    border-color: var(--primary-neon) !important;
    box-shadow: 0 0 15px rgba(0, 242, 255, 0.25);
    background: rgba(0, 242, 255, 0.05) !important;
  }

  .scan-tag-btn {
    font-size: 11px;
    color: var(--text-main);
    background: rgba(0, 242, 255, 0.03);
    border: 1px solid var(--panel-border);
    padding: 6px 12px;
    text-decoration: none;
    font-family: var(--font-mono);
    transition: all 0.3s ease;
    letter-spacing: 0.5px;
    display: inline-block;
  }

  .scan-tag-btn:hover {
    border-color: var(--primary-neon);
    background: rgba(0, 242, 255, 0.08);
    box-shadow: 0 0 10px rgba(0, 242, 255, 0.2);
    color: var(--primary-neon);
  }
</style>
