---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const dinosaurEntries = await getCollection('dinosaurs');
// 日本国内で発見された恐竜・古生物のみをフィルタリング
const DINOSAURS = dinosaurEntries
  .map(entry => entry.data)
  .filter(d => d.region && d.region.startsWith('日本'));

const REGION_CENTERS = {
  '北海道・樺太': { x: 1415, y: 235 },
  '東北': { x: 1265, y: 623 },
  '関東': { x: 1180, y: 940 },
  '中部・北陸': { x: 990, y: 940 },
  '近畿': { x: 830, y: 1040 },
  '中国・四国': { x: 600, y: 1100 },
  '九州・沖縄': { x: 425, y: 1200 }
};

// SVGホットスポット矩形の定義
const REGION_FRAMES = {
  '北海道・樺太': { x: 1150, y: 40, width: 530, height: 390 },
  '東北': { x: 1150, y: 430, width: 230, height: 385 },
  '関東': { x: 1090, y: 840, width: 180, height: 200 },
  '中部・北陸': { x: 880, y: 790, width: 220, height: 300 },
  '近畿': { x: 730, y: 950, width: 200, height: 180 },
  '中国・四国': { x: 450, y: 950, width: 300, height: 300 },
  '九州・沖縄': { x: 300, y: 1050, width: 250, height: 300 }
};

// 引き出し線のバッジ表示先座標 (重なりを防ぐためのオフセット座標)
const REGION_BADGES = {
  '北海道・樺太': { x: 1800, y: 150 },
  '東北': { x: 1580, y: 600 },
  '関東': { x: 1450, y: 1020 },
  '中部・北陸': { x: 1080, y: 1250 },
  '近畿': { x: 820, y: 850 },
  '中国・四国': { x: 600, y: 900 },
  '九州・沖縄': { x: 180, y: 1350 }
};

// エリア別透過画像の定義 (public/images/map/配下)
const REGION_IMAGES = {
  '北海道・樺太': 'cyber_hokkaido_map.webp',
  '東北': 'cyber_tohoku_map.webp',
  '関東': 'cyber_kanto_map.webp',
  '中部・北陸': 'cyber_chubu_map.webp',
  '近畿': 'cyber_kinki_map.webp',
  '中国・四国': 'cyber_chugoku・shikoku_map.webp',
  '九州・沖縄': 'cyber_kyushu・okinawa_map.webp'
};


const matchesRegion = (dinoRegion: string, targetRegion: string) => {
    if (!dinoRegion.startsWith('日本')) return false;
    
    if (targetRegion === '北海道・樺太') {
        return dinoRegion.includes('北海道') || dinoRegion.includes('樺太') || dinoRegion.includes('サハリン');
    }
    if (targetRegion === '東北') {
        return dinoRegion.includes('岩手') || dinoRegion.includes('宮城') || dinoRegion.includes('福島');
    }
    if (targetRegion === '関東') {
        return dinoRegion.includes('群馬') || dinoRegion.includes('関東');
    }
    if (targetRegion === '中部・北陸') {
        return dinoRegion.includes('福井') || dinoRegion.includes('石川') || dinoRegion.includes('岐阜') || dinoRegion.includes('中部') || dinoRegion.includes('北陸');
    }
    if (targetRegion === '近畿') {
        return dinoRegion.includes('兵庫') || dinoRegion.includes('和歌山') || dinoRegion.includes('近畿');
    }
    if (targetRegion === '中国・四国') {
        return dinoRegion.includes('中国') || dinoRegion.includes('四国');
    }
    if (targetRegion === '九州・沖縄') {
        return dinoRegion.includes('熊本') || dinoRegion.includes('福岡') || dinoRegion.includes('九州') || dinoRegion.includes('沖縄');
    }
    return false;
};

// 各セクターごとの恐竜登録数を集計
const regionCounts = Object.keys(REGION_CENTERS).reduce((acc, region) => {
    acc[region] = DINOSAURS.filter(d => matchesRegion(d.region || '', region)).length;
    return acc;
}, {} as Record<string, number>);

// 古生物ごとの発見地層マッピング
const DINO_FORMATIONS: Record<string, string> = {
  'fukuiraptor': '手取層群北谷層（白亜紀前期）',
  'fukuisaurus': '手取層群北谷層（白亜紀前期）',
  'fukuititan': '手取層群北谷層（白亜紀前期）',
  'fukuivenator': '手取層群北谷層（白亜紀前期）',
  'koshisaurus': '手取層群北谷層（白亜紀前期）',
  'kamuysaurus': '蝦夷層群函淵層（白亜紀後期）',
  'ezomikasaryu': '蝦夷層群（白亜紀後期）',
  'paralitherizinosaurus': '蝦夷層群（白亜紀後期）',
  'nipponosaurus': '川上層（白亜紀後期）',
  'moshiryu': '宮古層群（白亜紀前期）',
  'utatsusaurus': '大沢層（三畳紀前期）',
  'futabasaurus': '双葉層群玉山層（白亜紀後期）',
  'sanchuryu': '瀬林層（白亜紀前期）',
  'sasayamagnomus': '篠山層群大山下層（白亜紀前期）',
  'tambatitan': '篠山層群大山下層（白亜紀前期）',
  'yamatodraco': '和泉層群北阿万層（白亜紀後期）',
  'wakayama-soryu': '外和泉層群（白亜紀後期）',
  'wakinosaurus': '脇野亜層群（白亜紀前期）',
  'mifuneryu': '御船層群（白亜紀後期）'
};
---

<Layout title="日本マップ | Dino-Portal" activeTab="world-map" description="日本地図インターフェースによる日本産恐竜・古生物の地域分布および発掘地層スキャンシミュレータ。" ogImage="/images/map/japan/cyber_japan_map.webp">
    <section class="page-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
      <div>
        <h2 class="page-title">日本マップ</h2>
        <p class="page-subtitle" style="font-size: 15px;">発掘セクターをクリックして地層・古生物データをスキャン</p>
      </div>
      <div>
        <a href="/world-map/" class="cyber-link-btn">
          [ 世界地図へ ]
        </a>
      </div>
    </section>

    <div class="world-map-layout" id="japan-map-root" data-dinosaurs={JSON.stringify(DINOSAURS)} data-formations={JSON.stringify(DINO_FORMATIONS)}>
        <div class="map-3d-stage">
            <!-- マップコンテナ -->
            <div class="cyber-map-container" id="map-3d-container">
                <svg viewBox="0 0 1998 1529" class="cyber-world-map" id="map-hotspots-svg">
                    <image href="/images/map/japan/cyber_japan_map.webp" x="0" y="0" width="1998" height="1529" />
                    
                    <!-- エリア別透過画像レイヤーの重ね合わせ表示 -->
                    {Object.keys(REGION_IMAGES).map(region => {
                        const fileName = REGION_IMAGES[region as keyof typeof REGION_IMAGES];
                        return (
                            <image
                                class="region-image-layer"
                                data-region={region}
                                href={`/images/map/japan/${fileName}`}
                                x="0"
                                y="0"
                                width="1998"
                                height="1529"
                            />
                        );
                    })}
                    
                    <!-- セクターごとのホットスポット矩形（更新後のスキャン枠と100%一致する透明センサー） -->
                    {Object.keys(REGION_FRAMES).map(region => {
                        const frame = REGION_FRAMES[region as keyof typeof REGION_FRAMES];
                        return (
                            <rect
                                class="map-region-hotspot"
                                data-region={region}
                                fill="transparent"
                                stroke="transparent"
                                x={frame.x}
                                y={frame.y}
                                width={frame.width}
                                height={frame.height}
                                style="cursor: pointer;"
                            />
                        );
                    })}
                    
                    <!-- 九州・沖縄セクター用：沖縄インセット領域の第2のタッチセンサー -->
                    <rect
                        class="map-region-hotspot"
                        data-region="九州・沖縄"
                        fill="transparent"
                        stroke="transparent"
                        x="30"
                        y="50"
                        width="550"
                        height="500"
                        style="cursor: pointer;"
                    />


                    <!-- 各セクターの生物数バッジと引き出し線 -->
                    {Object.keys(REGION_CENTERS).map(region => {
                        const center = REGION_CENTERS[region as keyof typeof REGION_CENTERS];
                        const badge = REGION_BADGES[region as keyof typeof REGION_BADGES];
                        const count = regionCounts[region];
                        const label = region;
                        
                        return (
                            <g class="map-badge-group" style="pointer-events: none;">
                                <!-- サイバー引き出し線 -->
                                <line x1={center.x} y1={center.y} x2={badge.x} y2={badge.y} stroke="var(--primary-neon)" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.6" />
                                <circle cx={center.x} cy={center.y} r="5" fill="var(--primary-neon)" />
                                
                                <!-- 情報バッジ本体 -->
                                <g transform={`translate(${badge.x}, ${badge.y})`}>
                                    <rect x="-100" y="-27" width="200" height="54" rx="4" fill="rgba(4, 8, 12, 0.92)" stroke="var(--panel-border)" stroke-width="1.5" style="filter: drop-shadow(0 0 8px rgba(0, 242, 255, 0.15));" />
                                    <line x1="-96" y1="-20" x2="-96" y2="20" stroke="var(--primary-neon)" stroke-width="3" />
                                    <text x="-80" y="-4" text-anchor="start" fill="var(--text-main)" font-size="15" font-weight="bold" font-family="var(--font-mono)" letter-spacing="0.5">{label}</text>
                                    <text x="-80" y="15" text-anchor="start" fill="var(--secondary-neon)" font-size="16" font-weight="bold" font-family="var(--font-mono)">{count} 種の登録</text>
                                </g>
                            </g>
                        );
                    })}
                </svg>
            </div>
            
            <div class="map-scan-beam" id="scan-beam-el" style="display: none;"></div>
        </div>

        <div class="scan-terminal">
            <div class="terminal-header-bar">
                <span>日本セクタースキャンデータ</span>
                <div class="terminal-status-light"></div>
            </div>
            <div class="terminal-main-content" id="terminal-content">
                <div class="scan-init-msg">
                    <div class="scan-radar-icon">☵</div>
                    <p style="font-size: 14px; letter-spacing: 1.5px;">地図上のエリアを選択して詳細スキャンを実行してください。</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        const REGION_CENTERS: Record<string, {x: number, y: number}> = {
          '北海道・樺太': { x: 1415, y: 235 },
          '東北': { x: 1265, y: 623 },
          '関東': { x: 1180, y: 940 },
          '中部・北陸': { x: 990, y: 940 },
          '近畿': { x: 830, y: 1040 },
          '中国・四国': { x: 600, y: 1100 },
          '九州・沖縄': { x: 425, y: 1200 }
        };

        const REGION_FRAMES: Record<string, {x: number, y: number, width: number, height: number}> = {
          '北海道・樺太': { x: 1150, y: 40, width: 530, height: 390 },
          '東北': { x: 1150, y: 430, width: 230, height: 385 },
          '関東': { x: 1090, y: 840, width: 180, height: 200 },
          '中部・北陸': { x: 880, y: 790, width: 220, height: 300 },
          '近畿': { x: 730, y: 950, width: 200, height: 180 },
          '中国・四国': { x: 450, y: 950, width: 300, height: 300 },
          '九州・沖縄': { x: 300, y: 1050, width: 250, height: 300 }
        };

        const REGION_METADATA: Record<string, { description: string, formation: string }> = {
          '北海道・樺太': {
            description: '白亜紀後期の蝦夷層群（えぞそうぐん）などから、ほぼ完全な全身骨格の「カムイサウルス」や巨大な爪を持つテリジノサウルス類、さらには大型モササウルス類（エゾミカサリュウ）などが発見された北の巨大エリア。',
            formation: '蝦夷層群（白亜紀後期）など'
          },
          '東北': {
            description: '岩手県の宮古層群から発見された日本最初の恐竜化石「モシリュウ」や、宮城県で発見された最古級の魚竜「ウタツサウルス」、福島県の双葉層群から見つかった有名な首長竜「フタバサウルス（フタバスズキリュウ）」などが発掘された重要エリア。',
            formation: '宮古層群、双葉層群、大沢層など'
          },
          '関東': {
            description: '群馬県神流町の山中地溝帯（さんちゅうちこうたい）に分布する瀬林層（せばやしそう）から、オルニトミモサウルス類とされる「サンチュウリュウ」やスピノサウルス科の歯化石などが発掘されたエリア。',
            formation: '瀬林層（白亜紀前期）'
          },
          '中部・北陸': {
            description: '福井県勝山市の手取層群北谷層（てとりそうぐんきただにそう）から、フクイラプトル、フクイスaurus、フクイティタン、フukuivenator、コシサウルスなどの多種多様な恐竜が発掘され、全身骨格復元が行われた日本国内最大規模の恐竜王国。',
            formation: '手取層群北谷層（白亜紀前期）'
          },
          '近畿': {
            description: '兵庫県篠山市の篠山層群（ささやまそうぐん）から発見されたタンバティタンや最古級の角竜ササヤマグノムス、淡路島の和泉層群からハドロサウルス科のヤマトドラコ、和歌山県から大型モササウルス類が発掘された近畿主要地帯。',
            formation: '篠山層群、和泉層群（白亜紀前期〜後期）'
          },
          '中国・四国': {
            description: '現在、当アーカイブには恐竜・古生物データが登録されていません。今後の発掘調査と情報更新をお待ちください。',
            formation: '未検出'
          },
          '九州・沖縄': {
            description: '熊本県御船町の御船層群から発見された大型肉食恐竜の歯「ミフネリュウ」、福岡県の脇野亜層群から発見された肉食恐竜「ワキノサウルス」など、主に白亜紀の獣脚類（肉食恐竜）の手がかりが得られた西の重要エリア。',
            formation: '御船層群、脇野亜層群（白亜紀前期〜後期）'
          }
        };

        const matchesRegion = (dinoRegion: string, targetRegion: string) => {
            if (!dinoRegion.startsWith('日本')) return false;
            
            if (targetRegion === '北海道・樺太') {
                return dinoRegion.includes('北海道') || dinoRegion.includes('樺太') || dinoRegion.includes('サハリン');
            }
            if (targetRegion === '東北') {
                return dinoRegion.includes('岩手') || dinoRegion.includes('宮城') || dinoRegion.includes('福島');
            }
            if (targetRegion === '関東') {
                return dinoRegion.includes('群馬') || dinoRegion.includes('関東');
            }
            if (targetRegion === '中部・北陸') {
                return dinoRegion.includes('福井') || dinoRegion.includes('石川') || dinoRegion.includes('岐阜') || dinoRegion.includes('中部') || dinoRegion.includes('北陸');
            }
            if (targetRegion === '近畿') {
                return dinoRegion.includes('兵庫') || dinoRegion.includes('和歌山') || dinoRegion.includes('近畿');
            }
            if (targetRegion === '中国・四国') {
                return dinoRegion.includes('中国') || dinoRegion.includes('四国');
            }
            if (targetRegion === '九州・沖縄') {
                return dinoRegion.includes('熊本') || dinoRegion.includes('福岡') || dinoRegion.includes('九州') || dinoRegion.includes('沖縄');
            }
            return false;
        };

        // 学名未定（通称）の判定ロジック
        const isUndescribed = (dino: any) => {
            const scName = dino.scientificName || "";
            return scName.includes("indet.") || scName.includes("sp.") || scName.includes("gen.") || 
                   dino.id === "moshiryu" || dino.id === "ezomikasaryu" || dino.id === "sanchuryu";
        };

        const COLLECTION_KEY = 'dino_portal_saved_observations';

        function initJapanMap() {
            const hotspotsSvg = document.getElementById('map-hotspots-svg');
            const scanBeam = document.getElementById('scan-beam-el');
            const terminalContent = document.getElementById('terminal-content');
            const root = document.getElementById('japan-map-root');
            
            if (!hotspotsSvg || !terminalContent || !root) return;
            
            const dinosaursData = root.getAttribute('data-dinosaurs');
            const formationsData = root.getAttribute('data-formations');
            const DINOSAURS = dinosaursData ? JSON.parse(dinosaursData) : [];
            const DINO_FORMATIONS = formationsData ? JSON.parse(formationsData) : {};
            
            let isScanning = false;
            
            const getCollection = () => {
                const saved = localStorage.getItem(COLLECTION_KEY);
                return saved ? JSON.parse(saved) : [];
            };

            const renderDinoCards = (list: any[]) => {
                const collected = getCollection();
                return list.map(d => {
                    const isCollected = collected.includes(d.id);
                    const formation = DINO_FORMATIONS[d.id] || "地層情報解析中";
                    const isUnnamed = isUndescribed(d);
                    const nameTag = isUnnamed ? '<span class="card-tag unnamed-tag" style="background: rgba(255, 102, 0, 0.12); color: #ff6600; border: 1px solid rgba(255, 102, 0, 0.3); font-size: 10px; padding: 2px 6px; border-radius: 3px; font-weight: normal; margin-left: 5px; white-space: nowrap;">学名未定</span>' : '';
                    
                    return `
                        <div class="dino-card hud-panel ${isCollected ? 'is-collected' : ''}" onclick="location.href='/dictionary/${d.id}/'" style="cursor:pointer; display: flex; flex-direction: column;">
                            <div class="card-img-wrap">
                                <img src="/${d.image}" alt="${d.name}" loading="lazy" decoding="async" width="400" height="225">
                                ${isCollected ? '<div class="collected-badge">OBSERVED</div>' : ''}
                            </div>
                            <div class="card-info" style="flex: 1; display: flex; flex-direction: column; justify-content: space-between;">
                                <div>
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                        <h3 class="card-title" style="margin-bottom: 0; font-size: 16px;">${d.name}</h3>
                                        ${nameTag}
                                    </div>
                                    <div class="card-formation" style="font-size: 11px; color: var(--text-dim); margin-bottom: 12px; font-family: var(--font-sans);">
                                        発見地層: ${formation}
                                    </div>
                                </div>
                                <div class="card-tags" style="display: flex; gap: 5px; flex-wrap: wrap; margin-top: auto;">
                                    <span class="card-tag group-tag">${d.group || '未分類'}</span>
                                    <span class="card-tag">${d.era}</span>
                                    <span class="card-tag">${d.diet}</span>
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');
            };

            const getScannedDinoListHtml = (regionName: string) => {
                const list = DINOSAURS.filter(d => matchesRegion(d.region, regionName));
                const meta = REGION_METADATA[regionName] || { description: '', formation: '不明' };
                
                let resultGrid = '';
                if (list.length > 0) {
                    resultGrid = `
                        <div class="dino-grid">
                            ${renderDinoCards(list)}
                        </div>
                    `;
                } else {
                    resultGrid = `
                        <div style="text-align: center; padding: 40px 20px; border: 1px dashed var(--panel-border); background: rgba(255, 0, 85, 0.02); border-radius: 4px;">
                            <div style="font-size: 24px; color: var(--alert-neon); margin-bottom: 10px; font-family: var(--font-mono);">NO TELEMETRY SIGNALS</div>
                            <p style="font-size: 13px; color: var(--text-dim); line-height: 1.6;">この発掘エリアからの登録データはありません。<br>今後の発見や情報更新をお待ちください。</p>
                        </div>
                    `;
                }
                
                return `
                    <div class="scan-meta-details" style="animation: scan-info-fade 0.5s ease forwards; margin-bottom: 25px; border: none; background: none; padding: 0;">
                        <h3 style="color: var(--text-main); margin-bottom: 12px; font-size: 18px; font-weight: bold; letter-spacing: 0.5px;">選択エリア：${regionName}</h3>
                        <p style="font-size: 14px; line-height: 1.6; color: var(--text-main); margin-bottom: 15px;">${meta.description}</p>
                        
                        <div style="display: flex; gap: 20px; align-items: center; flex-wrap: wrap;">
                            <div style="font-size: 14px; color: var(--text-dim);">
                                主要地層: <span style="color: var(--text-main); font-weight: bold;">${meta.formation}</span>
                            </div>
                            <div style="font-size: 14px; font-weight: bold; color: var(--secondary-neon); font-family: var(--font-mono);">
                                登録古生物: ${list.length} 種
                            </div>
                        </div>
                    </div>
                    
                    ${resultGrid}
                `;
            };
            
            // ホバーによる画像レイヤー発光の制御
            hotspotsSvg.addEventListener('mouseover', (e) => {
                const target = e.target as HTMLElement;
                const hotspot = target.closest('.map-region-hotspot');
                if (hotspot) {
                    const region = hotspot.getAttribute('data-region');
                    if (region) {
                        const layer = document.querySelector(`.region-image-layer[data-region="${region}"]`);
                        if (layer && !layer.classList.contains('is-scanning')) {
                            layer.classList.add('is-hovered');
                        }
                    }
                }
            });

            hotspotsSvg.addEventListener('mouseout', (e) => {
                const target = e.target as HTMLElement;
                const hotspot = target.closest('.map-region-hotspot');
                if (hotspot) {
                    const region = hotspot.getAttribute('data-region');
                    if (region) {
                        const layer = document.querySelector(`.region-image-layer[data-region="${region}"]`);
                        if (layer) {
                            layer.classList.remove('is-hovered');
                        }
                    }
                }
            });

            hotspotsSvg.addEventListener('click', (e) => {
                const target = e.target as HTMLElement;
                const hotspot = target.closest('.map-region-hotspot');
                if (hotspot && !isScanning) {
                    const region = hotspot.getAttribute('data-region');
                    if (!region) return;
                    const center = REGION_CENTERS[region];
                    if (!center) return;
                    
                    isScanning = true;

                    // すべてのレイヤーから状態クラスを一旦削除
                    document.querySelectorAll('.region-image-layer').forEach(layer => {
                        layer.classList.remove('is-scanning', 'is-hovered');
                    });
                    // クリックされた地方をスキャン中状態（明滅）にする
                    const currentLayer = document.querySelector(`.region-image-layer[data-region="${region}"]`);
                    if (currentLayer) {
                        currentLayer.classList.add('is-scanning');
                    }
                    
                    // スキャン結果パネルへスムーズスクロール
                    const scanTerminal = document.querySelector('.scan-terminal');
                    if (scanTerminal) {
                        scanTerminal.scrollIntoView({ behavior: 'smooth' });
                    }
                    

                    
                    // スキャンビームのアニメーション
                    if (scanBeam) {
                        scanBeam.style.display = 'block';
                        scanBeam.style.top = '0%';
                        
                        let start: number | null = null;
                        const duration = 1200;
                        
                        function animateScanBeam(timestamp: number) {
                            if (!start) start = timestamp;
                            const progress = timestamp - start;
                            const percent = Math.min(100, (progress / duration) * 100);
                            scanBeam!.style.top = `${percent}%`;
                            
                            if (progress < duration) {
                                requestAnimationFrame(animateScanBeam);
                            } else {
                                scanBeam!.style.display = 'none';
                            }
                        }
                        requestAnimationFrame(animateScanBeam);
                    }
                    
                    // ターミナルの「デコード中」表示
                    terminalContent.innerHTML = `
                        <div class="scan-init-msg">
                            <div class="scan-radar-icon" style="color: var(--secondary-neon); animation: blink 0.5s infinite alternate;">☲</div>
                            <h3 style="color: var(--secondary-neon); font-family: var(--font-mono); letter-spacing: 2px;">DECODING SECTOR DATA...</h3>
                            <p style="font-family: var(--font-mono); font-size: 11px; color: var(--text-dim);">[SECTOR: ${region.toUpperCase()}]<br>SCANNING STRATIGRAPHIC PROFILES</p>
                            <div style="width: 100%; height: 6px; background: rgba(0, 242, 255, 0.05); border: 1px solid var(--panel-border); overflow: hidden; width: 200px; margin-top: 15px; margin-left: auto; margin-right: auto;">
                                <div id="decoder-progress-fill" style="width: 0%; height: 100%; background: var(--secondary-neon); box-shadow: 0 0 10px var(--secondary-neon);"></div>
                            </div>
                        </div>
                    `;
                    
                    const progressFill = document.getElementById('decoder-progress-fill');
                    let progressVal = 0;
                    const progressInterval = setInterval(() => {
                        progressVal += 10;
                        if (progressFill) progressFill.style.width = `${progressVal}%`;
                        if (progressVal >= 100) {
                            clearInterval(progressInterval);
                        }
                    }, 100);
                    
                    setTimeout(() => {
                        terminalContent.innerHTML = getScannedDinoListHtml(region);
                        isScanning = false;
                        if (currentLayer) {
                            currentLayer.classList.remove('is-scanning');
                        }
                    }, 1300);
                }
            });
        }

        document.addEventListener('astro:page-load', initJapanMap);
    </script>
    
    <style>
    .cyber-link-btn {
      display: inline-block;
      padding: 8px 16px;
      background: rgba(0, 242, 255, 0.05);
      border: 1px solid var(--primary-neon);
      color: var(--primary-neon);
      font-family: var(--font-mono);
      font-size: 13px;
      text-decoration: none;
      letter-spacing: 1px;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
      box-shadow: 0 0 5px rgba(0, 242, 255, 0.1);
      border-radius: 4px;
    }
    .cyber-link-btn:hover {
      background: rgba(0, 242, 255, 0.15);
      box-shadow: 0 0 15px rgba(0, 242, 255, 0.3);
      text-shadow: 0 0 5px var(--primary-neon);
    }
    
    /* 日本地図が縦長（1998x1529）であるため、高さ制限を完全に解除して見切れを防止 */
    .map-3d-stage {
      max-height: none !important;
      height: auto !important;
    }

    .cyber-map-container {
      aspect-ratio: 1998 / 1529 !important;
      width: 100% !important;
      max-width: 100% !important;
      height: auto !important;
      max-height: none !important;
    }

    .cyber-world-map {
      width: 100% !important;
      height: auto !important;
      display: block;
    }

    /* ホットスポット多角形（パズルピース型透明センサー） */
    .map-region-hotspot {
      fill: transparent;
      stroke: transparent;
      transition: all 0.3s ease;
    }
    .map-region-hotspot:hover {
      fill: transparent !important;
      stroke: transparent !important;
    }

    /* エリア別透過画像レイヤーの基本定義 */
    .region-image-layer {
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease, filter 0.3s ease;
    }

    /* ホバーされたエリアの発光演出 */
    .region-image-layer.is-hovered {
      opacity: 1 !important;
      filter: drop-shadow(0 0 15px var(--secondary-neon)) brightness(1.3) !important;
    }

    /* スキャン中のオレンジ警告パルス明滅演出 */
    .region-image-layer.is-scanning {
      opacity: 1 !important;
      filter: drop-shadow(0 0 20px #ff6600) brightness(1.4) !important;
      animation: scan-pulse-warn 0.6s infinite alternate;
    }

    @keyframes scan-pulse-warn {
      from { opacity: 0.35; }
      to { opacity: 1.0; }
    }
    </style>
</Layout>
