---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  activeTab?: string;
  ogImage?: string;
  ogType?: string;
}

const { 
  title, 
  description = 'Dino-Portal: デジタル恐竜図鑑。150種以上の恐竜データを最新の学説に基づき網羅。AI検索に最適化された次世代の生物学的アーカイブ。', 
  activeTab = 'home',
  ogImage = '/images/cyber_world_map.webp',
  ogType = 'website'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://dino-portal.com/');
const fullOgImageUrl = new URL(ogImage, 'https://dino-portal.com/');
---
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Favicon and App Icons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="canonical" href={canonicalURL.href}>
    
    <!-- Preconnect Google Fonts for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">

    <!-- Open Graph / Facebook (SEO & SNS) -->
    <meta property="og:type" content={ogType}>
    <meta property="og:url" content={canonicalURL.href}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={fullOgImageUrl.href}>

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content={canonicalURL.href}>
    <meta property="twitter:title" content={title}>
    <meta property="twitter:description" content={description}>
    <meta property="twitter:image" content={fullOgImageUrl.href}>

    <!-- Google Search Console verification -->
    {import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION} />
    )}

    <!-- Google Analytics (GA4) -->
    {import.meta.env.PUBLIC_GA_TRACKING_ID && (
      <>
        <script is:inline type="text/javascript" src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_TRACKING_ID}`} defer></script>
        <script is:inline type="text/javascript" define:vars={{ gaId: import.meta.env.PUBLIC_GA_TRACKING_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}

    <!-- Base Schema -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Dino-Portal Lab",
      "url": "https://dino-portal.com/",
      "logo": "https://dino-portal.com/logo.png",
      "description": "次世代の恐竜デジタルアーカイブプロジェクト"
    }
    </script>
    
    <ClientRouter />
</head>
<body class="hud-theme">
    <!-- Overlay effects -->
    <div class="scanlines" style="pointer-events: none;"></div>
    <div class="grid-overlay" style="pointer-events: none;"></div>
    <div class="noise-overlay" style="pointer-events: none;"></div>
 
    <header class="main-header">
        <a href="/" class="logo-container" style="text-decoration: none;">
            <span class="logo-prefix">プロジェクト</span>
            <span class="logo-text">DINO-PORTAL</span>
            <div class="status-indicator">ディノ・ポータル</div>
        </a>
        <nav class="nav-menu" aria-label="メインナビゲーション">
            <a href="/" class={`nav-link ${activeTab === 'home' ? 'active' : ''}`} aria-label="ホーム画面へ">
                <span class="nav-icon" aria-hidden="true">▤</span> ホーム
            </a>
            <a href="/dictionary" class={`nav-link ${activeTab === 'dictionary' ? 'active' : ''}`} aria-label="恐竜図鑑を表示">
                <span class="nav-icon" aria-hidden="true">☷</span> 恐竜図鑑
            </a>
            <a href="/world-map" class={`nav-link ${activeTab === 'world-map' ? 'active' : ''}`} aria-label="世界地図から探索">
                <span class="nav-icon" aria-hidden="true">◰</span> 世界地図
            </a>
            <a href="/topics" class={`nav-link ${activeTab === 'topics' ? 'active' : ''}`} aria-label="恐竜に関するトピックスを読む">
                <span class="nav-icon" aria-hidden="true">▧</span> トピックス
            </a>
            <a href="/my-collection" class={`nav-link ${activeTab === 'my-collection' ? 'active' : ''}`} aria-label="自分の観測データを確認">
                <span class="nav-icon" aria-hidden="true">📊</span> マイ図鑑
            </a>
            <a href="/quiz" class={`nav-link ${activeTab === 'quiz' ? 'active' : ''}`} aria-label="恐竜クイズに挑戦">
                <span class="nav-icon" aria-hidden="true">☵</span> クイズ
            </a>
            <a href="/about" class={`nav-link ${activeTab === 'about' ? 'active' : ''}`} aria-label="このサイトと運営者について">
                <span class="nav-icon" aria-hidden="true">👤</span> プロフィール
            </a>
            <a href="/contact" class={`nav-link ${activeTab === 'contact' ? 'active' : ''}`} aria-label="お問い合わせ">
                <span class="nav-icon" aria-hidden="true">✉</span> お問い合わせ
            </a>
        </nav>
    </header>

    <main id="app-container">
        <div id="app-content-wrapper">
            <slot />
        </div>
    </main>

    <footer class="main-footer">
        <div class="ai-disclaimer" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
            <span>本図鑑の視覚データは、最新の古生物学的知見に基づきAIによって生成されたシミュレーション画像です。</span>
            <div class="footer-links" style="display: flex; gap: 15px;">
                <a href="/privacy" class="footer-privacy-link" style="color: var(--primary-neon); text-decoration: none; font-size: 11px; font-family: var(--font-mono); transition: opacity 0.3s ease;">
                    [ PRIVACY POLICY ]
                </a>
                <a href="/contact" class="footer-privacy-link" style="color: var(--primary-neon); text-decoration: none; font-size: 11px; font-family: var(--font-mono); transition: opacity 0.3s ease;">
                    [ CONTACT ]
                </a>
            </div>
        </div>
        <div class="terminal-footer">
            <div class="footer-left">
                <span class="term-prompt">></span>
                <span class="typing-text">アーカイブ走査中...</span>
            </div>
            <div class="footer-right">
                <span class="coord">LAT: 35.6895 N</span>
                <span class="coord">LON: 139.6917 E</span>
                <span class="version">V.2026.4.5</span>
            </div>
        </div>
    </footer>

    <!-- フッタータイピングアニメーション用スクリプト -->
    <script>
        document.addEventListener('astro:page-load', () => {
            const footerText = document.querySelector('.typing-text');
            if (!footerText) return;
            const texts = ["遺伝子配列を解析中...", "古生物データベースを更新中...", "アーカイブと同期中...", "新しい発見をスキャン中..."];
            let i = 0;
            // 既存のタイマーがあればクリアする（View Transitions時に対策）
            if ((window as any)._footerInterval) {
                clearInterval((window as any)._footerInterval);
            }
            (window as any)._footerInterval = setInterval(() => {
                footerText.innerText = texts[i];
                i = (i + 1) % texts.length;
            }, 4000);
        });
    </script>
</body>
</html>
