<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 450" width="100%" height="100%">
  <!-- 背景 -->
  <rect width="800" height="450" fill="#0d1117" stroke="#00f2ff" stroke-width="2"/>
  
  <!-- サイバー装飾（角） -->
  <path d="M 0 40 L 40 0" stroke="#00f2ff" stroke-width="2" fill="none"/>
  <path d="M 760 0 L 800 40" stroke="#00f2ff" stroke-width="2" fill="none"/>
  <path d="M 800 410 L 760 450" stroke="#00f2ff" stroke-width="2" fill="none"/>
  <path d="M 40 450 L 0 410" stroke="#00f2ff" stroke-width="2" fill="none"/>
  
  <!-- HUDグリッド＆ライン -->
  <line x1="20" y1="20" x2="120" y2="20" stroke="#00f2ff" stroke-width="1" stroke-dasharray="5,5" opacity="0.6"/>
  <line x1="20" y1="20" x2="20" y2="120" stroke="#00f2ff" stroke-width="1" stroke-dasharray="5,5" opacity="0.6"/>
  <line x1="780" y1="20" x2="680" y2="20" stroke="#00f2ff" stroke-width="1" stroke-dasharray="5,5" opacity="0.6"/>
  <line x1="780" y1="20" x2="780" y2="120" stroke="#00f2ff" stroke-width="1" stroke-dasharray="5,5" opacity="0.6"/>
  
  <!-- 装飾円 -->
  <circle cx="400" cy="225" r="150" stroke="#00f2ff" stroke-width="1" stroke-dasharray="3,9" fill="none" opacity="0.2"/>
  <circle cx="400" cy="225" r="180" stroke="#00f2ff" stroke-width="1" fill="none" opacity="0.1"/>
  
  <!-- テキストエリア -->
  <text x="400" y="180" fill="#00f2ff" font-family="monospace" font-size="14" font-weight="bold" text-anchor="middle" letter-spacing="2" opacity="0.8">
    SYSTEM STATUS: PLACEHOLDER ACTIVE
  </text>
  
  <text x="400" y="230" fill="#ffffff" font-family="'Helvetica Neue', Arial, sans-serif" font-size="28" font-weight="bold" text-anchor="middle" letter-spacing="3">
    ILLUSTRATION COMING SOON
  </text>
  
  <text x="400" y="270" fill="#00f2ff" font-family="'Helvetica Neue', Arial, sans-serif" font-size="16" text-anchor="middle">
    【モササウルスのキービジュアル】イラスト配置予定地
  </text>
  
  <text x="400" y="315" fill="#8b949e" font-family="monospace" font-size="12" text-anchor="middle" opacity="0.7">
    DIMENSIONS: 800 x 450 PX | TARGET ID: topic-mosasaurus
  </text>
  
  <!-- 下部HUDバー -->
  <rect x="250" y="340" width="300" height="4" fill="#00f2ff" opacity="0.3"/>
  <rect x="380" y="340" width="40" height="4" fill="#00f2ff"/>
</svg>
